---
// SSR — renders on each request so Contentful changes go live instantly
export const prerender = false;

import BaseLayout from '@/layouts/BaseLayout.astro';
import { fetchEntry, getSuppliers } from '@/lib/contentful';
import type { SupplierSkeleton } from '@/lib/contentful/types';

// ─── Fetch this supplier from Contentful by slug ─────────────────────
const { slug } = Astro.params;
const entry = await fetchEntry<SupplierSkeleton>('supplier', slug!, false);

if (!entry) {
  return Astro.redirect('/suppliers');
}

// ─── Rich text → plain text ──────────────────────────────────────────
function richTextToPlain(doc: any): string {
  if (!doc || typeof doc === 'string') return doc || '';
  if (!doc.content) return '';
  return doc.content
    .map((node: any) => {
      if (node.nodeType === 'paragraph' || node.nodeType?.startsWith('heading')) {
        return (node.content || []).map((child: any) => child.value || '').join('');
      }
      if (node.nodeType === 'unordered-list' || node.nodeType === 'ordered-list') {
        return (node.content || [])
          .map((li: any) => (li.content || [])
            .map((p: any) => (p.content || []).map((c: any) => c.value || '').join(''))
            .join(''))
          .join('\n');
      }
      return '';
    })
    .filter(Boolean)
    .join('\n\n');
}

// ─── Rich text → HTML (preserves bold, italic, bullets, headings) ────
function richTextToHtml(doc: any): string {
  if (!doc || typeof doc === 'string') return doc ? `<p>${doc}</p>` : '';
  if (!doc.content) return '';

  function inlineToHtml(node: any): string {
    if (node.nodeType === 'text') {
      let text = node.value || '';
      if (!text) return '';
      // Escape HTML entities
      text = text.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
      const marks: string[] = (node.marks || []).map((m: any) => m.type);
      if (marks.includes('bold'))   text = `<strong>${text}</strong>`;
      if (marks.includes('italic')) text = `<em>${text}</em>`;
      if (marks.includes('code'))   text = `<code>${text}</code>`;
      if (marks.includes('underline')) text = `<u>${text}</u>`;
      return text;
    }
    if (node.nodeType === 'hyperlink') {
      const href = node.data?.uri || '#';
      const inner = (node.content || []).map(inlineToHtml).join('');
      return `<a href="${href}" target="_blank" rel="noopener noreferrer" class="text-primary underline hover:no-underline">${inner}</a>`;
    }
    return (node.content || []).map(inlineToHtml).join('');
  }

  function blockToHtml(node: any): string {
    const inner = (node.content || []).map(inlineToHtml).join('');
    switch (node.nodeType) {
      case 'paragraph':
        return inner.trim() ? `<p>${inner}</p>` : '';
      case 'heading-1': return `<h1 class="text-2xl font-bold text-brand-navy mt-6 mb-2">${inner}</h1>`;
      case 'heading-2': return `<h2 class="text-xl font-bold text-brand-navy mt-5 mb-2">${inner}</h2>`;
      case 'heading-3': return `<h3 class="text-lg font-semibold text-brand-navy mt-4 mb-1">${inner}</h3>`;
      case 'heading-4': return `<h4 class="text-base font-semibold text-brand-navy mt-3 mb-1">${inner}</h4>`;
      case 'unordered-list': {
        const items = (node.content || [])
          .map((li: any) => `<li>${(li.content || []).map(blockToHtml).join('')}</li>`)
          .join('');
        return `<ul>${items}</ul>`;
      }
      case 'ordered-list': {
        const items = (node.content || [])
          .map((li: any) => `<li>${(li.content || []).map(blockToHtml).join('')}</li>`)
          .join('');
        return `<ol>${items}</ol>`;
      }
      case 'list-item':
        return (node.content || []).map(blockToHtml).join('');
      case 'blockquote':
        return `<blockquote class="border-l-4 border-slate-200 pl-4 italic text-slate-500 my-4">${inner}</blockquote>`;
      case 'hr':
        return '<hr class="border-slate-200 my-6" />';
      default:
        return inner ? `<p>${inner}</p>` : '';
    }
  }

  return doc.content.map(blockToHtml).filter(Boolean).join('\n');
}

// ─── Map fields ──────────────────────────────────────────────────────
const f = entry.fields as any;
const s = {
  name:             f.name || '',
  slug:             f.slug || '',
  shortDescription: f.shortDescription || '',
  description:      richTextToPlain(f.description),
  descriptionHtml:  richTextToHtml(f.description),
  categories:       (f.categories || []).filter((c: any) => c?.fields?.name).map((c: any) => c.fields.name),
  website:          f.website || '',
  contactEmail:     f.contactEmail || '',
  contactPhone:     f.contactPhone || '',
  contactName:      f.contactName || '',
  logoUrl:          f.logo?.fields?.file?.url ? `https:${f.logo.fields.file.url}` : '',
  featured:         f.featured || false,
  benefit1:         richTextToPlain(f.benefit1),
  benefit1Html:     richTextToHtml(f.benefit1),
  benefit2:         richTextToPlain(f.benefit2),
  benefit2Html:     richTextToHtml(f.benefit2),
  memberOffer:      richTextToPlain(f.memberOffer),
  memberOfferHtml:  richTextToHtml(f.memberOffer),
  targetAudience:   f.targetAudience || '',
  typicalUsers:     f.typicalUsers || '',
  integrations:     richTextToPlain(f.integrations),
  integrationsHtml: richTextToHtml(f.integrations),
};

// ─── Derived values ──────────────────────────────────────────────────
const initials = s.name
  .split(/[\s-]+/)
  .filter((w: string) => w.length > 0 && w[0] === w[0].toUpperCase())
  .slice(0, 2)
  .map((w: string) => w[0])
  .join('') || s.name.slice(0, 2).toUpperCase();

const hues = [210, 160, 340, 25, 270, 190, 45, 300, 140, 15];
const hash = s.name.split('').reduce((acc: number, c: string) => acc + c.charCodeAt(0), 0);
const hue = hues[hash % hues.length];
const accentColor = `hsl(${hue}, 55%, 48%)`;
const accentColorLight = `hsl(${hue}, 55%, 96%)`;
const accentColorBorder = `hsl(${hue}, 55%, 88%)`;

const hasLogo = !!(s.logoUrl && s.logoUrl.startsWith('http'));

const showOffer = s.memberOffer
  && !s.memberOffer.toLowerCase().includes('join recconnect')
  && !s.memberOffer.toLowerCase().includes('join the club');

// ─── Related suppliers ───────────────────────────────────────────────
const allEntries = await getSuppliers({ include: 2 });
const related = allEntries
  .filter((e: any) => e.fields.slug !== s.slug)
  .filter((e: any) => {
    const cats = (e.fields.categories || [])
      .filter((c: any) => c?.fields?.name)
      .map((c: any) => c.fields.name);
    return cats.some((c: string) => s.categories.includes(c));
  })
  .slice(0, 4)
  .map((e: any) => {
    const ef = e.fields;
    const relHash = (ef.name || '').split('').reduce((acc: number, c: string) => acc + c.charCodeAt(0), 0);
    const relHue = hues[relHash % hues.length];
    return {
      name:             ef.name || '',
      slug:             ef.slug || '',
      shortDescription: ef.shortDescription || '',
      description:      richTextToPlain(ef.description),
      categories:       (ef.categories || []).filter((c: any) => c?.fields?.name).map((c: any) => c.fields.name),
      logoUrl:          ef.logo?.fields?.file?.url ? `https:${ef.logo.fields.file.url}` : '',
      hue:              relHue,
    };
  });

// ─── SEO ─────────────────────────────────────────────────────────────
const seoTitle = `${s.name} | RecConnect Supplier Directory`;

// Auto-generate meta description: prefer shortDescription, else truncate description
const rawDesc = s.shortDescription || s.description;
const seoDescription = rawDesc.length > 155
  ? rawDesc.slice(0, 152).trimEnd() + '…'
  : rawDesc;

// Keywords from categories + name
const seoKeywords = [s.name, ...s.categories, 'recruitment supplier', 'RecConnect'].join(', ');

// Canonical
const canonicalUrl = `https://recconnect.co.uk/suppliers/${s.slug}`;

// JSON-LD structured data
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: s.name,
  description: seoDescription,
  url: s.website ? (s.website.startsWith('http') ? s.website : `https://${s.website}`) : canonicalUrl,
  ...(hasLogo && { logo: s.logoUrl }),
  ...(s.contactEmail && { email: s.contactEmail }),
  ...(s.contactPhone && { telephone: s.contactPhone }),
  ...(s.categories.length > 0 && { keywords: s.categories.join(', ') }),
};
---

<BaseLayout
  title={seoTitle}
  noSuffix={true}
  description={seoDescription}
  keywords={seoKeywords}
  image={hasLogo ? s.logoUrl : undefined}
  canonical={canonicalUrl}
>

  <!-- ─── JSON-LD ─────────────────────────────────────────────────── -->
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} slot="head" />

  <!-- ═══ HERO ═══ -->
  <!-- Single unified section: back nav + identity + content. Accent hue tints the background. -->
  <!-- Bottom fades to white so there is no hard cut between dark hero and content. -->
  <section class="relative overflow-hidden bg-brand-navy pt-36 pb-0 md:pt-44">

    {/* Grid texture */}
    <div class="absolute inset-0 opacity-[0.03]" style="background-image: url('data:image/svg+xml,%3Csvg width=&quot;40&quot; height=&quot;40&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;%3E%3Cpath d=&quot;M0 0h40v40H0z&quot; fill=&quot;none&quot; stroke=&quot;%23fff&quot; stroke-width=&quot;.5&quot;/%3E%3C/svg%3E');"></div>

    {/* Accent hue radial glow — bottom-left so it sits behind content */}
    <div class="absolute bottom-0 left-0 w-[700px] h-[400px] rounded-full blur-[140px] pointer-events-none" style={`background: radial-gradient(ellipse at 20% 80%, hsl(${hue}, 60%, 50%, 0.18) 0%, transparent 70%);`}></div>

    {/* Soft right glow for depth */}
    <div class="absolute top-1/2 right-0 w-[400px] h-[400px] rounded-full blur-[120px] pointer-events-none" style={`background: radial-gradient(ellipse, hsl(${hue}, 55%, 48%, 0.08) 0%, transparent 70%);`}></div>

    <div class="container-wide relative z-10">

      {/* Back nav */}
      <a href="/suppliers" class="inline-flex items-center gap-1.5 text-sm text-slate-400 hover:text-white transition-colors mb-10">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
        </svg>
        Back to Supplier Directory
      </a>

      {/* Hero identity block — coloured left border, vertical card layout */}
      <div class="pb-12 md:pb-16">
        <div class="flex gap-0">

          {/* Coloured left border strip */}
          <div class="w-1 rounded-full flex-shrink-0 mr-8" style={`background: ${accentColor};`}></div>

          {/* Content */}
          <div class="flex-1 min-w-0 flex flex-col gap-5">

            {/* Logo — wide pill, fixed height so landscape logos look right */}
            {hasLogo && (
              <div class="inline-flex">
                <div
                  class="bg-white/95 rounded-xl overflow-hidden flex items-center justify-center px-5"
                  style="height: 56px; max-width: 220px;"
                >
                  <img
                    src={s.logoUrl}
                    alt={`${s.name} logo`}
                    class="max-h-8 w-auto object-contain"
                  />
                </div>
              </div>
            )}

            {/* Name + badges row */}
            <div>
              <div class="flex flex-wrap items-center gap-2 mb-3">
                {/* Colour initials badge — inline, small */}
                <span
                  class="inline-flex items-center justify-center w-8 h-8 rounded-lg text-xs font-bold text-white flex-shrink-0"
                  style={`background: ${accentColor};`}
                  aria-hidden="true"
                >
                  {initials}
                </span>

                {s.featured && (
                  <span class="inline-flex items-center gap-1 rounded-full bg-primary px-3 py-1 text-xs font-semibold text-white">
                    <svg class="h-3 w-3" fill="currentColor" viewBox="0 0 24 24">
                      <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
                    </svg>
                    Featured Partner
                  </span>
                )}

                {s.categories.map((cat: string) => (
                  <span
                    class="inline-block rounded-lg px-3 py-1 text-xs font-medium border"
                    style={`background: hsl(${hue}, 55%, 48%, 0.15); color: hsl(${hue}, 60%, 80%); border-color: hsl(${hue}, 55%, 48%, 0.3);`}
                  >
                    {cat}
                  </span>
                ))}
              </div>

              <h1 class="text-3xl md:text-5xl font-bold text-white mb-4 tracking-tight">
                {s.name}
              </h1>

              {(s.shortDescription || s.description) && (
                <p class="text-lg text-slate-400 leading-relaxed max-w-2xl">
                  {s.shortDescription || s.description.slice(0, 200)}
                </p>
              )}
            </div>

            {/* Action buttons */}
            <div class="flex flex-wrap items-center gap-3">
              {s.website && (
                <a
                  href={s.website.startsWith('http') ? s.website : `https://${s.website}`}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="btn-primary"
                >
                  Visit Website
                  <svg class="w-4 h-4 ml-1.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                  </svg>
                </a>
              )}
              {s.contactEmail && (
                <a href={`mailto:${s.contactEmail}`} class="btn-outline-light">
                  <svg class="w-4 h-4 mr-1.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                  </svg>
                  Get in Touch
                </a>
              )}
              {s.contactPhone && (
                <a href={`tel:${s.contactPhone.replace(/[\s()]/g, '')}`} class="btn-outline-light">
                  <svg class="w-4 h-4 mr-1.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                  </svg>
                  {s.contactPhone}
                </a>
              )}
            </div>

          </div>
        </div>
      </div>
    </div>

  </section>

  <!-- ═══ DETAIL CONTENT ═══ -->
  <section class="bg-white py-12 md:py-16">
    <div class="container-wide">
      <div class="grid lg:grid-cols-3 gap-10 lg:gap-14">

        {/* Main content — left 2 cols */}
        <div class="lg:col-span-2 space-y-10">

          {/* About — full description */}
          {s.descriptionHtml && s.description !== s.shortDescription && (
            <div>
              <h2 class="text-lg font-bold text-brand-navy mb-4">About {s.name}</h2>
              <div class="rich-text" set:html={s.descriptionHtml} />
            </div>
          )}

          {/* Key Benefits */}
          {(s.benefit1 || s.benefit2) && (
            <div>
              <h2 class="text-lg font-bold text-brand-navy mb-4">Key Benefits</h2>
              <div class="space-y-4">
                {s.benefit1 && (
                  <div class="flex items-start gap-3 p-4 rounded-xl border" style={`background: ${accentColorLight}; border-color: ${accentColorBorder};`}>
                    <div class="flex-shrink-0 w-8 h-8 rounded-lg flex items-center justify-center mt-0.5" style={`background: ${accentColor}20;`}>
                      <svg class="w-4 h-4" style={`color: ${accentColor};`} fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                      </svg>
                    </div>
                    <div class="rich-text text-slate-700" set:html={s.benefit1Html} />
                  </div>
                )}
                {s.benefit2 && (
                  <div class="flex items-start gap-3 p-4 rounded-xl border" style={`background: ${accentColorLight}; border-color: ${accentColorBorder};`}>
                    <div class="flex-shrink-0 w-8 h-8 rounded-lg flex items-center justify-center mt-0.5" style={`background: ${accentColor}20;`}>
                      <svg class="w-4 h-4" style={`color: ${accentColor};`} fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                      </svg>
                    </div>
                    <div class="rich-text text-slate-700" set:html={s.benefit2Html} />
                  </div>
                )}
              </div>
            </div>
          )}

          {/* Integrations */}
          {s.integrations && (
            <div>
              <h2 class="text-lg font-bold text-brand-navy mb-4">Integrations</h2>
              <div class="p-4 rounded-xl bg-slate-50 border border-slate-100">
                <div class="flex items-start gap-3">
                  <div class="flex-shrink-0 w-8 h-8 rounded-lg bg-blue-50 flex items-center justify-center mt-0.5">
                    <svg class="w-4 h-4 text-primary" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" />
                    </svg>
                  </div>
                  <div class="rich-text text-slate-700" set:html={s.integrationsHtml} />
                </div>
              </div>
            </div>
          )}

          {/* Member Offer */}
          {showOffer && (
            <div>
              <h2 class="text-lg font-bold text-brand-navy mb-4">RecConnect Member Offer</h2>
              <div class="p-5 rounded-xl bg-amber-50 border border-amber-200/60">
                <div class="flex items-start gap-3">
                  <span class="text-2xl flex-shrink-0">🎁</span>
                  <div>
                    <div class="rich-text rich-text--amber" set:html={s.memberOfferHtml} />
                    <a href="/join" class="inline-flex items-center gap-1 text-sm text-primary font-medium mt-2 hover:underline">
                      Join RecConnect to access this offer
                      <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                      </svg>
                    </a>
                  </div>
                </div>
              </div>
            </div>
          )}
        </div>

        {/* Sidebar */}
        <div class="space-y-6">

          {/* Quick Info */}
          {(s.targetAudience || s.typicalUsers || s.categories.length > 0) && (
            <div class="rounded-xl border border-slate-200 p-5 space-y-4">
              <h3 class="font-bold text-brand-navy text-sm uppercase tracking-wide">Quick Info</h3>

              {s.targetAudience && (
                <div>
                  <p class="text-xs font-medium text-slate-400 uppercase tracking-wide mb-1">Target Audience</p>
                  <p class="text-sm text-slate-700">{s.targetAudience}</p>
                </div>
              )}

              {s.typicalUsers && (
                <div>
                  <p class="text-xs font-medium text-slate-400 uppercase tracking-wide mb-1">Typical Users</p>
                  <p class="text-sm text-slate-700">{s.typicalUsers}</p>
                </div>
              )}

              {s.categories.length > 0 && (
                <div>
                  <p class="text-xs font-medium text-slate-400 uppercase tracking-wide mb-1.5">Categories</p>
                  <div class="flex flex-wrap gap-1.5">
                    {s.categories.map((cat: string) => (
                      <a
                        href={`/suppliers#${cat}`}
                        class="inline-block rounded-md px-2.5 py-1 text-xs font-medium border transition-colors hover:opacity-80"
                        style={`background: ${accentColorLight}; color: hsl(${hue}, 45%, 35%); border-color: ${accentColorBorder};`}
                      >
                        {cat}
                      </a>
                    ))}
                  </div>
                </div>
              )}
            </div>
          )}

          {/* Contact */}
          {(s.contactName || s.contactEmail || s.contactPhone || s.website) && (
            <div class="rounded-xl border border-slate-200 p-5 space-y-3">
              <h3 class="font-bold text-brand-navy text-sm uppercase tracking-wide">Contact</h3>

              {s.contactName && (
                <div class="flex items-center gap-2">
                  <svg class="w-4 h-4 text-slate-400 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                  </svg>
                  <p class="text-sm text-slate-700">{s.contactName}</p>
                </div>
              )}

              {s.contactEmail && (
                <a href={`mailto:${s.contactEmail}`} class="flex items-center gap-2 group">
                  <svg class="w-4 h-4 text-slate-400 group-hover:text-primary transition-colors flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                  </svg>
                  <p class="text-sm text-slate-700 group-hover:text-primary transition-colors break-all">{s.contactEmail}</p>
                </a>
              )}

              {s.contactPhone && (
                <a href={`tel:${s.contactPhone.replace(/[\s()]/g, '')}`} class="flex items-center gap-2 group">
                  <svg class="w-4 h-4 text-slate-400 group-hover:text-primary transition-colors flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                  </svg>
                  <p class="text-sm text-slate-700 group-hover:text-primary transition-colors">{s.contactPhone}</p>
                </a>
              )}

              {s.website && (
                <a
                  href={s.website.startsWith('http') ? s.website : `https://${s.website}`}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="flex items-center gap-2 group"
                >
                  <svg class="w-4 h-4 text-slate-400 group-hover:text-primary transition-colors flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9" />
                  </svg>
                  <p class="text-sm text-slate-700 group-hover:text-primary transition-colors truncate">
                    {s.website.replace(/^https?:\/\//, '').replace(/\/$/, '')}
                  </p>
                </a>
              )}
            </div>
          )}

          {/* CTA Card — uses accent colour */}
          {(s.contactEmail || s.website) && (
            <div class="rounded-xl p-5 text-center text-white" style={`background: ${accentColor};`}>
              <p class="font-medium text-sm mb-3 opacity-90">Interested in {s.name}?</p>
              {s.contactEmail ? (
                <a
                  href={`mailto:${s.contactEmail}?subject=Enquiry via RecConnect`}
                  class="block w-full py-2.5 px-4 rounded-lg bg-white/20 hover:bg-white/30 text-white text-sm font-semibold transition-colors border border-white/20"
                >
                  Contact {s.contactName || s.name}
                </a>
              ) : (
                <a
                  href={s.website.startsWith('http') ? s.website : `https://${s.website}`}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="block w-full py-2.5 px-4 rounded-lg bg-white/20 hover:bg-white/30 text-white text-sm font-semibold transition-colors border border-white/20"
                >
                  Visit Website
                </a>
              )}
            </div>
          )}
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ RELATED SUPPLIERS ═══ -->
  {related.length > 0 && (
    <section class="bg-slate-50 py-12 md:py-16 border-t border-slate-200">
      <div class="container-wide">
        <h2 class="text-xl font-bold text-brand-navy mb-6">Related Suppliers</h2>
        <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
          {related.map((r: any) => {
            const rHasLogo = !!(r.logoUrl && r.logoUrl.startsWith('http'));
            const rInitials = r.name.split(/[\s-]+/).filter((w: string) => w.length > 0 && w[0] === w[0].toUpperCase()).slice(0, 2).map((w: string) => w[0]).join('') || r.name.slice(0, 2).toUpperCase();
            const rColor = `hsl(${r.hue}, 55%, 48%)`;
            const rColorLight = `hsl(${r.hue}, 55%, 96%)`;
            return (
              <a href={`/suppliers/${r.slug}`} class="block rounded-xl border border-slate-200 bg-white p-4 hover:shadow-md hover:-translate-y-0.5 transition-all overflow-hidden">
                {/* Colour accent top strip */}
                <div class="h-1 -mx-4 -mt-4 mb-3 rounded-t-xl" style={`background: ${rColor};`}></div>
                <div class="flex items-center gap-3 mb-2">
                  {rHasLogo ? (
                    <div class="w-9 h-9 rounded-lg bg-slate-50 border border-slate-100 overflow-hidden flex items-center justify-center p-1 flex-shrink-0">
                      <img src={r.logoUrl} alt={r.name} class="w-full h-full object-contain" loading="lazy" />
                    </div>
                  ) : (
                    <div class="w-9 h-9 rounded-lg flex items-center justify-center text-xs font-bold text-white flex-shrink-0" style={`background: ${rColor};`}>
                      {rInitials}
                    </div>
                  )}
                  <h3 class="font-semibold text-brand-navy text-sm leading-tight">{r.name}</h3>
                </div>
                <p class="text-xs text-slate-500 line-clamp-2">{r.shortDescription || r.description}</p>
                {r.categories.length > 0 && (
                  <div class="flex flex-wrap gap-1 mt-2">
                    {r.categories.slice(0, 2).map((cat: string) => (
                      <span class="text-[0.65rem] rounded px-1.5 py-0.5 border" style={`background: ${rColorLight}; color: hsl(${r.hue}, 45%, 35%); border-color: hsl(${r.hue}, 55%, 88%);`}>{cat}</span>
                    ))}
                  </div>
                )}
              </a>
            );
          })}
        </div>
      </div>
    </section>
  )}

  <!-- ═══ BACK TO DIRECTORY ═══ -->
  <section class="relative overflow-hidden bg-[#0a0e17] py-12">
    <div class="absolute inset-0 opacity-[0.15]" style="background-image: url('data:image/svg+xml,%3Csvg%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%20width%3D%22800%22%20height%3D%22600%22%3E%3Cline%20x1%3D%22509%22%20y1%3D%2225%22%20x2%3D%22407%22%20y2%3D%2263%22%20stroke%3D%22%234299e1%22%20stroke-width%3D%220.4%22%2F%3E%3Cline%20x1%3D%22201%22%20y1%3D%2291%22%20x2%3D%22188%22%20y2%3D%22178%22%20stroke%3D%22%234299e1%22%20stroke-width%3D%220.3%22%2F%3E%3C%2Fsvg%3E'); background-size: 800px 600px;"></div>
    <div class="absolute bottom-0 left-1/2 -translate-x-1/2 w-[600px] h-[300px] bg-primary/6 rounded-full blur-[150px]"></div>
    <div class="container-narrow text-center relative z-10">
      <p class="text-slate-400 mb-4">Looking for something else?</p>
      <a href="/suppliers" class="btn-primary">Browse All Suppliers</a>
    </div>
  </section>

</BaseLayout>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* Rich text — :global() required so styles reach set:html injected content */
  .rich-text :global(p)             { color: #374151; line-height: 1.75; margin-bottom: 1rem; }
  .rich-text :global(p:last-child)  { margin-bottom: 0; }
  .rich-text :global(strong)        { font-weight: 600; color: #111827; }
  .rich-text :global(em)            { font-style: italic; }
  .rich-text :global(code)          { font-family: monospace; font-size: 0.875em; background: #f1f5f9; padding: 0.1em 0.3em; border-radius: 3px; }
  .rich-text :global(ul)            { list-style: disc; padding-left: 1.5rem; margin-bottom: 1rem; color: #374151; }
  .rich-text :global(ol)            { list-style: decimal; padding-left: 1.5rem; margin-bottom: 1rem; color: #374151; }
  .rich-text :global(li)            { margin-bottom: 0.4rem; line-height: 1.7; }
  .rich-text :global(li p)          { margin-bottom: 0.25rem; }
  .rich-text :global(a)             { color: #2563eb; text-decoration: underline; }
  .rich-text :global(a:hover)       { text-decoration: none; }
  .rich-text :global(blockquote)    { border-left: 4px solid #e2e8f0; padding-left: 1rem; color: #64748b; font-style: italic; margin: 1rem 0; }
  .rich-text :global(h1), .rich-text :global(h2),
  .rich-text :global(h3), .rich-text :global(h4) { margin-top: 1.5rem; margin-bottom: 0.5rem; }
  .rich-text :global(h1:first-child), .rich-text :global(h2:first-child),
  .rich-text :global(h3:first-child)              { margin-top: 0; }

  /* Amber variant for member offer */
  .rich-text--amber :global(p)             { color: #78350f; font-weight: 500; }
  .rich-text--amber :global(p:last-child)  { margin-bottom: 0; }
  .rich-text--amber :global(strong)        { color: #431407; }
  .rich-text--amber :global(ul), .rich-text--amber :global(ol) { color: #78350f; }
  .rich-text--amber :global(a)             { color: #b45309; }
</style>
