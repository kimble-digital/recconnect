---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { suppliersData } from '@/data/suppliers';
// Future: import { fetchEntry } from '@/lib/contentful';

// ─── Static paths for build ─────────────────────────────────────────
export function getStaticPaths() {
  return suppliersData.map(s => ({
    params: { slug: s.slug },
    props: { supplier: s },
  }));
}

const { supplier } = Astro.props;
const s = supplier;

// Generate initials for fallback
const initials = s.name
  .split(/[\s-]+/)
  .filter((w: string) => w.length > 0 && w[0] === w[0].toUpperCase())
  .slice(0, 2)
  .map((w: string) => w[0])
  .join('') || s.name.slice(0, 2).toUpperCase();

const hues = [210, 160, 340, 25, 270, 190, 45, 300, 140, 15];
const hash = s.name.split('').reduce((acc: number, c: string) => acc + c.charCodeAt(0), 0);
const hue = hues[hash % hues.length];

const hasLogo = s.logoUrl && (s.logoUrl.startsWith('http') || s.logoUrl.startsWith('/lovable-uploads'));
const showOffer = s.memberOffer
  && !s.memberOffer.toLowerCase().includes('join recconnect')
  && !s.memberOffer.toLowerCase().includes('join the club');

// Find related suppliers (same category, different supplier)
const related = suppliersData
  .filter(r => r.slug !== s.slug && r.categories.some((c: string) => s.categories.includes(c)))
  .slice(0, 4);
---

<BaseLayout
  title={s.name}
  description={s.shortDescription || s.description}
>

  <!-- ═══ BACK NAV ═══ -->
  <section class="relative overflow-hidden bg-brand-navy pt-36 pb-0 md:pt-44">
    <div class="absolute inset-0 opacity-[0.03]" style="background-image: url('data:image/svg+xml,%3Csvg width=&quot;40&quot; height=&quot;40&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;%3E%3Cpath d=&quot;M0 0h40v40H0z&quot; fill=&quot;none&quot; stroke=&quot;%23fff&quot; stroke-width=&quot;.5&quot;/%3E%3C/svg%3E');"></div>
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[600px] h-[300px] bg-primary/10 rounded-full blur-[120px]"></div>
    <div class="container-wide relative z-10">
      <a href="/suppliers" class="inline-flex items-center gap-1.5 text-sm text-slate-400 hover:text-white transition-colors">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
        </svg>
        Back to Supplier Directory
      </a>
    </div>
  </section>

  <!-- ═══ HERO / HEADER ═══ -->
  <section class="bg-brand-navy pt-8 pb-12 md:pb-16">
    <div class="container-wide">
      <div class="flex flex-col md:flex-row items-start gap-6 md:gap-8">
        {/* Logo */}
        <div class="flex-shrink-0">
          {hasLogo ? (
            <div class="w-20 h-20 md:w-24 md:h-24 rounded-2xl bg-white/10 border border-white/10 overflow-hidden flex items-center justify-center p-2">
              <img
                src={s.logoUrl}
                alt={`${s.name} logo`}
                class="w-full h-full object-contain"
              />
            </div>
          ) : (
            <div
              class="w-20 h-20 md:w-24 md:h-24 rounded-2xl flex items-center justify-center text-2xl font-bold text-white"
              style={`background: hsl(${hue}, 55%, 48%);`}
            >
              {initials}
            </div>
          )}
        </div>

        {/* Info */}
        <div class="flex-1 min-w-0">
          <div class="flex flex-wrap items-center gap-3 mb-3">
            {s.featured && (
              <span class="inline-flex items-center gap-1 rounded-full bg-primary px-3 py-1 text-xs font-semibold text-white">
                <svg class="h-3 w-3" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
                </svg>
                Featured Partner
              </span>
            )}
            {s.categories.map((cat: string) => (
              <span class="inline-block rounded-lg bg-white/10 px-3 py-1 text-xs font-medium text-slate-300">
                {cat}
              </span>
            ))}
          </div>

          <h1 class="text-3xl md:text-4xl font-bold text-white mb-3 tracking-tight">
            {s.name}
          </h1>

          <p class="text-lg text-slate-400 leading-relaxed max-w-2xl">
            {s.shortDescription || s.description}
          </p>

          {/* Action buttons */}
          <div class="flex flex-wrap items-center gap-3 mt-6">
            {s.website && (
              <a
                href={s.website.startsWith('http') ? s.website : `https://${s.website}`}
                target="_blank"
                rel="noopener noreferrer"
                class="btn-primary"
              >
                Visit Website
                <svg class="w-4 h-4 ml-1.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                </svg>
              </a>
            )}
            {s.contactEmail && (
              <a
                href={`mailto:${s.contactEmail}`}
                class="btn-outline-light"
              >
                <svg class="w-4 h-4 mr-1.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
                Get in Touch
              </a>
            )}
            {s.contactPhone && (
              <a
                href={`tel:${s.contactPhone.replace(/[\s()]/g, '')}`}
                class="btn-outline-light"
              >
                <svg class="w-4 h-4 mr-1.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                </svg>
                {s.contactPhone}
              </a>
            )}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ DETAIL CONTENT ═══ -->
  <section class="bg-white py-12 md:py-16">
    <div class="container-wide">
      <div class="grid lg:grid-cols-3 gap-10 lg:gap-14">

        {/* Main content — left 2 cols */}
        <div class="lg:col-span-2 space-y-10">

          {/* Key Benefits */}
          {(s.benefit1 || s.benefit2) && (
            <div>
              <h2 class="text-lg font-bold text-brand-navy mb-4">Key Benefits</h2>
              <div class="space-y-4">
                {s.benefit1 && (
                  <div class="flex items-start gap-3 p-4 rounded-xl bg-slate-50 border border-slate-100">
                    <div class="flex-shrink-0 w-8 h-8 rounded-lg bg-primary/10 flex items-center justify-center mt-0.5">
                      <svg class="w-4 h-4 text-primary" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                      </svg>
                    </div>
                    <p class="text-slate-700 leading-relaxed">{s.benefit1}</p>
                  </div>
                )}
                {s.benefit2 && (
                  <div class="flex items-start gap-3 p-4 rounded-xl bg-slate-50 border border-slate-100">
                    <div class="flex-shrink-0 w-8 h-8 rounded-lg bg-primary/10 flex items-center justify-center mt-0.5">
                      <svg class="w-4 h-4 text-primary" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                      </svg>
                    </div>
                    <p class="text-slate-700 leading-relaxed">{s.benefit2}</p>
                  </div>
                )}
              </div>
            </div>
          )}

          {/* Integrations */}
          {s.integrations && (
            <div>
              <h2 class="text-lg font-bold text-brand-navy mb-4">Integrations</h2>
              <div class="p-4 rounded-xl bg-slate-50 border border-slate-100">
                <div class="flex items-start gap-3">
                  <div class="flex-shrink-0 w-8 h-8 rounded-lg bg-blue-50 flex items-center justify-center mt-0.5">
                    <svg class="w-4 h-4 text-primary" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" />
                    </svg>
                  </div>
                  <p class="text-slate-700 leading-relaxed">{s.integrations}</p>
                </div>
              </div>
            </div>
          )}

          {/* Member Offer */}
          {showOffer && (
            <div>
              <h2 class="text-lg font-bold text-brand-navy mb-4">RecConnect Member Offer</h2>
              <div class="p-5 rounded-xl bg-amber-50 border border-amber-200/60">
                <div class="flex items-start gap-3">
                  <span class="text-2xl">🎁</span>
                  <div>
                    <p class="text-amber-900 font-medium leading-relaxed">{s.memberOffer}</p>
                    <a href="/join" class="inline-flex items-center gap-1 text-sm text-primary font-medium mt-2 hover:underline">
                      Join RecConnect to access this offer
                      <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                      </svg>
                    </a>
                  </div>
                </div>
              </div>
            </div>
          )}
        </div>

        {/* Sidebar — right col */}
        <div class="space-y-6">
          {/* Quick Info Card */}
          <div class="rounded-xl border border-slate-200 p-5 space-y-4">
            <h3 class="font-bold text-brand-navy text-sm uppercase tracking-wide">Quick Info</h3>

            {s.targetAudience && (
              <div>
                <p class="text-xs font-medium text-slate-400 uppercase tracking-wide mb-1">Target Audience</p>
                <p class="text-sm text-slate-700">{s.targetAudience}</p>
              </div>
            )}

            {s.typicalUsers && (
              <div>
                <p class="text-xs font-medium text-slate-400 uppercase tracking-wide mb-1">Typical Users</p>
                <p class="text-sm text-slate-700">{s.typicalUsers}</p>
              </div>
            )}

            {s.categories.length > 0 && (
              <div>
                <p class="text-xs font-medium text-slate-400 uppercase tracking-wide mb-1.5">Categories</p>
                <div class="flex flex-wrap gap-1.5">
                  {s.categories.map((cat: string) => (
                    <a
                      href={`/suppliers#${cat}`}
                      class="inline-block rounded-md bg-slate-100 px-2.5 py-1 text-xs font-medium text-slate-600 hover:bg-primary/10 hover:text-primary transition-colors"
                    >
                      {cat}
                    </a>
                  ))}
                </div>
              </div>
            )}
          </div>

          {/* Contact Card */}
          {(s.contactName || s.contactEmail || s.contactPhone) && (
            <div class="rounded-xl border border-slate-200 p-5 space-y-3">
              <h3 class="font-bold text-brand-navy text-sm uppercase tracking-wide">Contact</h3>

              {s.contactName && (
                <div class="flex items-center gap-2">
                  <svg class="w-4 h-4 text-slate-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                  </svg>
                  <p class="text-sm text-slate-700">{s.contactName}</p>
                </div>
              )}

              {s.contactEmail && (
                <a href={`mailto:${s.contactEmail}`} class="flex items-center gap-2 group">
                  <svg class="w-4 h-4 text-slate-400 group-hover:text-primary transition-colors" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                  </svg>
                  <p class="text-sm text-slate-700 group-hover:text-primary transition-colors">{s.contactEmail}</p>
                </a>
              )}

              {s.contactPhone && (
                <a href={`tel:${s.contactPhone.replace(/[\s()]/g, '')}`} class="flex items-center gap-2 group">
                  <svg class="w-4 h-4 text-slate-400 group-hover:text-primary transition-colors" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                  </svg>
                  <p class="text-sm text-slate-700 group-hover:text-primary transition-colors">{s.contactPhone}</p>
                </a>
              )}

              {s.website && (
                <a
                  href={s.website.startsWith('http') ? s.website : `https://${s.website}`}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="flex items-center gap-2 group"
                >
                  <svg class="w-4 h-4 text-slate-400 group-hover:text-primary transition-colors" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9" />
                  </svg>
                  <p class="text-sm text-slate-700 group-hover:text-primary transition-colors truncate">{s.website.replace(/^https?:\/\//, '').replace(/\/$/, '')}</p>
                </a>
              )}
            </div>
          )}

          {/* CTA Card */}
          <div class="rounded-xl bg-brand-navy p-5 text-center">
            <p class="text-white font-medium text-sm mb-3">Interested in {s.name}?</p>
            {s.contactEmail ? (
              <a
                href={`mailto:${s.contactEmail}?subject=Enquiry via RecConnect`}
                class="btn-primary w-full text-sm"
              >
                Contact {s.contactName || s.name}
              </a>
            ) : s.website ? (
              <a
                href={s.website.startsWith('http') ? s.website : `https://${s.website}`}
                target="_blank"
                rel="noopener noreferrer"
                class="btn-primary w-full text-sm"
              >
                Visit Website
              </a>
            ) : null}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ RELATED SUPPLIERS ═══ -->
  {related.length > 0 && (
    <section class="bg-slate-50 py-12 md:py-16 border-t border-slate-200">
      <div class="container-wide">
        <h2 class="text-xl font-bold text-brand-navy mb-6">Related Suppliers</h2>
        <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
          {related.map(r => (
            <a href={`/suppliers/${r.slug}`} class="block rounded-xl border border-slate-200 bg-white p-4 hover:shadow-md hover:-translate-y-0.5 transition-all">
              <div class="flex items-center gap-3 mb-2">
                {r.logoUrl && (r.logoUrl.startsWith('http') || r.logoUrl.startsWith('/lovable-uploads')) ? (
                  <div class="w-9 h-9 rounded-lg bg-slate-50 border border-slate-100 overflow-hidden flex items-center justify-center p-0.5">
                    <img src={r.logoUrl} alt={r.name} class="w-full h-full object-contain" loading="lazy" />
                  </div>
                ) : (
                  <div class="w-9 h-9 rounded-lg bg-primary/10 flex items-center justify-center text-xs font-bold text-primary">
                    {r.name.slice(0, 2).toUpperCase()}
                  </div>
                )}
                <h3 class="font-semibold text-brand-navy text-sm">{r.name}</h3>
              </div>
              <p class="text-xs text-slate-500 line-clamp-2">{r.shortDescription || r.description}</p>
              <div class="flex flex-wrap gap-1 mt-2">
                {r.categories.slice(0, 2).map((cat: string) => (
                  <span class="text-[0.65rem] rounded bg-slate-100 px-1.5 py-0.5 text-slate-500">{cat}</span>
                ))}
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- ═══ BACK TO DIRECTORY CTA ═══ -->
