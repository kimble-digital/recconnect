<!-- ═══ STYLES ═══ -->
<style>
  .category-pill {
    @apply inline-flex items-center gap-1.5 px-3.5 py-2 rounded-full text-sm font-medium 
           transition-all duration-200 cursor-pointer border
           bg-white/[0.05] border-white/10 text-slate-400 hover:text-white hover:bg-white/10;
  }
  .category-pill.active {
    @apply bg-primary border-primary text-white shadow-sm shadow-primary/20;
  }
  .pill-count {
    @apply text-xs opacity-60;
  }
  .category-pill.active .pill-count {
    @apply opacity-80;
  }

  .supplier-card {
    animation: cardIn 0.3s ease-out both;
  }
  @keyframes cardIn {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .supplier-card:nth-child(1) { animation-delay: 0ms; }
  .supplier-card:nth-child(2) { animation-delay: 30ms; }
  .supplier-card:nth-child(3) { animation-delay: 60ms; }
  .supplier-card:nth-child(4) { animation-delay: 90ms; }
  .supplier-card:nth-child(5) { animation-delay: 120ms; }
  .supplier-card:nth-child(6) { animation-delay: 150ms; }
  .supplier-card:nth-child(7) { animation-delay: 180ms; }
  .supplier-card:nth-child(8) { animation-delay: 210ms; }
</style>

<!-- ═══ CLIENT-SIDE FILTERING ═══ -->
<script>
  document.addEventListener('DOMContentLoaded', () => {
    const searchInput = document.getElementById('supplier-search') as HTMLInputElement;
    const searchClear = document.getElementById('search-clear') as HTMLElement;
    const grid = document.getElementById('suppliers-grid') as HTMLElement;
    const featuredSection = document.getElementById('featured-section') as HTMLElement | null;
    const emptyState = document.getElementById('empty-state') as HTMLElement;
    const resultsCount = document.getElementById('results-count') as HTMLElement;
    const resultsSection = document.getElementById('results-section') as HTMLElement;
    const clearFiltersBtn = document.getElementById('clear-filters') as HTMLElement;
    const pills = document.querySelectorAll('.category-pill') as NodeListOf<HTMLButtonElement>;
    const cards = grid.querySelectorAll('.supplier-card') as NodeListOf<HTMLElement>;

    // Hero collapse elements
    const heroSection = document.getElementById('hero-section') as HTMLElement;
    const heroIntro = document.getElementById('hero-intro') as HTMLElement;
    const searchHint = document.getElementById('search-results-hint') as HTMLElement;
    const searchCountEl = document.getElementById('search-results-count') as HTMLElement;
    const scrollToResultsBtn = document.getElementById('scroll-to-results') as HTMLElement;

    let activeCategory = 'all';
    let searchTerm = '';

    // Collapse/expand the hero intro based on search state
    function updateHeroState(isSearching: boolean) {
      if (isSearching) {
        heroIntro.style.maxHeight = '0px';
        heroIntro.style.opacity = '0';
        heroIntro.style.marginBottom = '0';
        heroSection.style.paddingBottom = '2rem';
        searchHint.style.maxHeight = '40px';
        searchHint.style.opacity = '1';
      } else {
        heroIntro.style.maxHeight = '400px';
        heroIntro.style.opacity = '1';
        heroIntro.style.marginBottom = '';
        heroSection.style.paddingBottom = '';
        searchHint.style.maxHeight = '0';
        searchHint.style.opacity = '0';
      }
    }

    // Gentle scroll to results
    function scrollToResults() {
      const rect = resultsSection.getBoundingClientRect();
      if (rect.top > 120) {
        const targetY = resultsSection.offsetTop - 80;
        window.scrollTo({ top: targetY, behavior: 'smooth' });
      }
    }

    function filterCards(shouldScroll = false) {
      let visible = 0;

      cards.forEach(card => {
        const name = card.dataset.name || '';
        const desc = card.dataset.description || '';
        const cats: string[] = JSON.parse(card.dataset.categories || '[]');

        const matchesCategory = activeCategory === 'all' || cats.includes(activeCategory);
        const matchesSearch = !searchTerm ||
          name.includes(searchTerm) ||
          desc.includes(searchTerm) ||
          cats.some(c => c.toLowerCase().includes(searchTerm));

        const show = matchesCategory && matchesSearch;
        card.style.display = show ? '' : 'none';
        if (show) visible++;
      });

      // Update count text
      if (searchTerm || activeCategory !== 'all') {
        const label = activeCategory !== 'all' ? ` in ${activeCategory}` : '';
        resultsCount.textContent = `Showing ${visible} supplier${visible !== 1 ? 's' : ''}${label}`;
      } else {
        resultsCount.textContent = `Showing ${cards.length} suppliers across all categories`;
      }

      // Update search hint count
      searchCountEl.textContent = `${visible} result${visible !== 1 ? 's' : ''} found`;

      // Toggle empty state
      emptyState.classList.toggle('hidden', visible > 0);
      grid.classList.toggle('hidden', visible === 0);

      // Hide featured section when filtering
      if (featuredSection) {
        featuredSection.style.display = (activeCategory !== 'all' || searchTerm) ? 'none' : '';
      }

      // Show/hide search clear
      searchClear.style.display = searchTerm ? '' : 'none';

      // Scroll to results when clicking category pills
      if (shouldScroll && (searchTerm || activeCategory !== 'all')) {
        scrollToResults();
      }
    }

    // Search: collapse hero, filter in place, no scroll
    searchInput.addEventListener('input', () => {
      searchTerm = searchInput.value.toLowerCase().trim();
      activeCategory = 'all';
      pills.forEach(p => { p.classList.remove('active'); p.setAttribute('aria-selected', 'false'); });
      pills[0]?.classList.add('active');
      pills[0]?.setAttribute('aria-selected', 'true');
      updateHeroState(!!searchTerm);
      filterCards(false);
    });

    // "View results" link in search hint
    scrollToResultsBtn?.addEventListener('click', () => {
      scrollToResults();
    });

    searchClear.querySelector('button')?.addEventListener('click', () => {
      searchInput.value = '';
      searchTerm = '';
      updateHeroState(activeCategory !== 'all');
      filterCards(false);
      if (activeCategory === 'all') {
        window.scrollTo({ top: 0, behavior: 'smooth' });
      }
      searchInput.focus();
    });

    pills.forEach(pill => {
      pill.addEventListener('click', () => {
        pills.forEach(p => { p.classList.remove('active'); p.setAttribute('aria-selected', 'false'); });
        pill.classList.add('active');
        pill.setAttribute('aria-selected', 'true');
        activeCategory = pill.dataset.category || 'all';
        updateHeroState(activeCategory !== 'all' || !!searchTerm);
        filterCards(false);
      });
    });

    clearFiltersBtn?.addEventListener('click', () => {
      searchInput.value = '';
      searchTerm = '';
      activeCategory = 'all';
      updateHeroState(false);
      pills.forEach(p => { p.classList.remove('active'); p.setAttribute('aria-selected', 'false'); });
      pills[0]?.classList.add('active');
      pills[0]?.setAttribute('aria-selected', 'true');
      filterCards(false);
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });
  });
</script>
