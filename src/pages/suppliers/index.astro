---
import BaseLayout from '@/layouts/BaseLayout.astro';
import SupplierCard from '@/components/SupplierCard.astro';
import { suppliersData } from '@/data/suppliers';
// Future Contentful swap:
// import { getSuppliers, getCategories } from '@/lib/contentful';
// const suppliers = await getSuppliers({ order: 'fields.name' });

// ─── Prepare data ────────────────────────────────────────────────────
const suppliers = suppliersData;

// Extract unique categories sorted alphabetically
const allCategories = [...new Set(suppliers.flatMap(s => s.categories))].sort();

// Separate featured from rest
const featured = suppliers.filter(s => s.featured);
const allSorted = [...suppliers].sort((a, b) => a.name.localeCompare(b.name));

// Category counts
const categoryCounts: Record<string, number> = {};
for (const cat of allCategories) {
  categoryCounts[cat] = suppliers.filter(s => s.categories.includes(cat)).length;
}
---

<BaseLayout
  title="Supplier Directory"
  description={`Discover trusted recruitment tools and services recommended by our community. Browse ${suppliers.length}+ suppliers across ${allCategories.length} categories.`}
>

  <!-- ═══ HERO ═══ -->
  <section class="relative overflow-hidden bg-brand-navy pt-36 pb-12 md:pt-44 md:pb-16 transition-all duration-500" id="hero-section">
    <div class="absolute inset-0 opacity-[0.03]" style="background-image: url('data:image/svg+xml,%3Csvg width=&quot;40&quot; height=&quot;40&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;%3E%3Cpath d=&quot;M0 0h40v40H0z&quot; fill=&quot;none&quot; stroke=&quot;%23fff&quot; stroke-width=&quot;.5&quot;/%3E%3C/svg%3E');"></div>
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[600px] h-[300px] bg-primary/10 rounded-full blur-[120px]"></div>

    <div class="container-wide relative z-10 text-center">
      {/* Collapsible intro — fades/collapses when searching */}
      <div id="hero-intro" class="transition-all duration-500 overflow-hidden" style="max-height: 400px; opacity: 1;">
        <div class="inline-flex items-center gap-2 rounded-full bg-primary/10 border border-primary/20 px-4 py-1.5 mb-6">
          <span class="w-2 h-2 rounded-full bg-primary animate-pulse"></span>
          <span class="text-primary text-sm font-medium">{suppliers.length} trusted suppliers</span>
        </div>

        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white mb-4 tracking-tight">
          Supplier <span class="text-primary">Directory</span>
        </h1>
        <p class="text-lg md:text-xl text-slate-400 max-w-2xl mx-auto mb-8 leading-relaxed">
          Discover tools, platforms and services trusted by the UK recruitment community — all vetted and recommended by your peers.
        </p>
      </div>

      {/* Search bar — always visible */}
      <div class="max-w-xl mx-auto">
        <div class="relative group">
          <svg class="absolute left-4 top-1/2 -translate-y-1/2 w-5 h-5 text-slate-500 group-focus-within:text-primary transition-colors" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
          <input
            type="text"
            placeholder="Search by name, category or service..."
            class="w-full pl-12 pr-12 py-3.5 bg-white/[0.07] backdrop-blur border border-white/10 rounded-xl text-white placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-primary/50 focus:border-primary/30 transition-all"
            id="supplier-search"
          />
          <div class="absolute right-3 top-1/2 -translate-y-1/2 hidden" id="search-clear">
            <button class="p-1 rounded-md text-slate-500 hover:text-white hover:bg-white/10 transition-colors" aria-label="Clear search">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
              </svg>
            </button>
          </div>
        </div>

        {/* Live search results indicator — appears when typing */}
        <div id="search-results-hint" class="mt-3 transition-all duration-300 overflow-hidden" style="max-height: 0; opacity: 0;">
          <p class="text-sm text-slate-400">
            <span id="search-results-count" class="text-primary font-medium">0 results</span>
            <span class="text-slate-500 mx-1.5">·</span>
            <button id="scroll-to-results" class="text-slate-400 hover:text-white transition-colors inline-flex items-center gap-1">
              View results
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
              </svg>
            </button>
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ CATEGORY PILLS ═══ -->
  <section class="bg-brand-navy pb-10">
    <div class="container-wide">
      <div class="flex flex-wrap justify-center gap-2" id="category-filters" role="tablist">
        <button class="category-pill active" data-category="all" role="tab" aria-selected="true">
          All <span class="pill-count">{suppliers.length}</span>
        </button>
        {allCategories.map(cat => (
          <button class="category-pill" data-category={cat} role="tab" aria-selected="false">
            {cat} <span class="pill-count">{categoryCounts[cat]}</span>
          </button>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ FEATURED PARTNERS ═══ -->
  {featured.length > 0 && (
    <section class="bg-slate-50 py-12 md:py-16 border-b border-slate-200" id="featured-section">
      <div class="container-wide">
        <div class="flex items-center gap-3 mb-8">
          <div class="flex items-center justify-center w-9 h-9 rounded-lg bg-amber-100">
            <svg class="w-5 h-5 text-amber-600" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
            </svg>
          </div>
          <div>
            <h2 class="text-xl font-bold text-brand-navy">Featured Partners</h2>
            <p class="text-sm text-slate-500">Recommended by the RecConnect community</p>
          </div>
        </div>

        <div class="grid sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-5">
          {featured.map(s => (
            <SupplierCard {...s} />
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- ═══ ALL SUPPLIERS GRID ═══ -->
  <section class="bg-white py-12 md:py-16" id="results-section">
    <div class="container-wide">
      <div class="flex items-center justify-between mb-8">
        <div>
          <h2 class="text-xl font-bold text-brand-navy">All Suppliers</h2>
          <p class="text-sm text-slate-500" id="results-count">
            Showing {allSorted.length} suppliers across {allCategories.length} categories
          </p>
        </div>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-5" id="suppliers-grid">
        {allSorted.map(s => (
          <SupplierCard {...s} />
        ))}
      </div>

      {/* Empty state */}
      <div class="hidden text-center py-16" id="empty-state">
        <div class="w-16 h-16 rounded-2xl bg-slate-100 mx-auto mb-4 flex items-center justify-center">
          <svg class="w-8 h-8 text-slate-400" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z" />
          </svg>
        </div>
        <h3 class="text-lg font-semibold text-brand-navy mb-1">No suppliers found</h3>
        <p class="text-slate-500 text-sm mb-4">Try a different search term or category.</p>
        <button class="text-primary font-medium text-sm hover:underline" id="clear-filters">Clear all filters</button>
      </div>
    </div>
  </section>

  <!-- ═══ BECOME A SUPPLIER CTA ═══ -->
  <section class="relative overflow-hidden bg-[#0a0e17] py-16 md:py-20">
    <div class="absolute inset-0 opacity-[0.15]" style="background-image: url('data:image/svg+xml,%3Csvg%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%20width%3D%22800%22%20height%3D%22600%22%3E%3Cline%20x1%3D%22509%22%20y1%3D%2225%22%20x2%3D%22407%22%20y2%3D%2263%22%20stroke%3D%22%234299e1%22%20stroke-width%3D%220.4%22%2F%3E%3Cline%20x1%3D%22509%22%20y1%3D%2225%22%20x2%3D%22469%22%20y2%3D%2214%22%20stroke%3D%22%234299e1%22%20stroke-width%3D%220.4%22%2F%3E%3Cline%20x1%3D%22201%22%20y1%3D%2291%22%20x2%3D%22160%22%20y2%3D%2250%22%20stroke%3D%22%234299e1%22%20stroke-width%3D%220.4%22%2F%3E%3Cline%20x1%3D%22201%22%20y1%3D%2291%22%20x2%3D%22188%22%20y2%3D%22178%22%20stroke%3D%22%234299e1%22%20stroke-width%3D%220.3%22%2F%3E%3Cline%20x1%3D%22201%22%20y1%3D%2291%22%20x2%3D%22323%22%20y2%3D%2248%22%20stroke%3D%22%234299e1%22%20stroke-width%3D%220.4%22%2F%3E%3Cline%20x1%3D%22201%22%20y1%3D%2291%22%20x2%3D%22197%22%20y2%3D%22150%22%20stroke%3D%22%234299e1%22%20stroke-width%3D%220.4%22%2F%3E%3Cline%20x1%3D%22538%22%20y1%3D%22527%22%20x2%3D%22492%22%20y2%3D%22510%22%20stroke%3D%22%234299e1%22%20stroke-width%3D%220.3%22%2F%3E%3Cline%20x1%3D%22538%22%20y1%3D%22527%22%20x2%3D%22466%22%20y2%3D%22531%22%20stroke%3D%22%234299e1%22%20stroke-width%3D%220.2%22%2F%3E%3Cline%20x1%3D%22471%22%20y1%3D%2228%22%20x2%3D%22407%22%20y2%3D%2263%22%20stroke%3D%22%234299e1%22%20stroke-width%3D%220.3%22%2F%3E%3Cline%20x1%3D%22471%22%20y1%3D%2228%22%20x2%3D%22541%22%20y2%3D%2276%22%20stroke%3D%22%234299e1%22%20stroke-width%3D%220.4%22%2F%3E%3Cline%20x1%3D%22471%22%20y1%3D%2228%22%20x2%3D%22406%22%20y2%3D%2272%22%20stroke%3D%22%234299e1%22%20stroke-width%3D%220.3%22%2F%3E%3Cline%20x1%3D%22471%22%20y1%3D%2228%22%20x2%3D%22607%22%20y2%3D%2284%22%20stroke%3D%22%234299e1%22%20stroke-width%3D%220.3%22%2F%3E%3Cline%20x1%3D%22471%22%20y1%3D%2228%22%20x2%3D%22502%22%20y2%3D%22143%22%20stroke%3D%22%234299e1%22%20stroke-width%3D%220.4%22%2F%3E%3Cline%20x1%3D%22181%22%20y1%3D%22303%22%20x2%3D%22188%22%20y2