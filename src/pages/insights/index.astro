<style>
  .article-pill {
    @apply inline-flex items-center gap-1 px-3 py-1.5 rounded text-xs font-medium
           transition-all duration-200 cursor-pointer
           text-slate-400 hover:text-white;
  }
  .article-pill.active {
    @apply bg-primary text-white;
  }
  .pill-count {
    @apply text-[0.6rem] opacity-60;
  }
  .article-pill.active .pill-count {
    @apply opacity-80;
  }

  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .article-card {
    animation: cardIn 0.25s ease-out both;
  }
  @keyframes cardIn {
    from { opacity: 0; transform: translateY(6px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const pills = document.querySelectorAll('.article-pill') as NodeListOf<HTMLButtonElement>;
    const cards = document.querySelectorAll('.article-card') as NodeListOf<HTMLElement>;
    const secondaryItems = document.querySelectorAll('.article-secondary') as NodeListOf<HTMLElement>;
    const featuredSection = document.getElementById('featured-section') as HTMLElement;
    const emptyState = document.getElementById('empty-state') as HTMLElement;
    const grid = document.getElementById('articles-grid') as HTMLElement;

    const featuredLink = featuredSection?.querySelector('a[data-category]') as HTMLElement | null;
    const featuredCategory = featuredLink?.dataset.category;

    pills.forEach(pill => {
      pill.addEventListener('click', () => {
        pills.forEach(p => { p.classList.remove('active'); p.setAttribute('aria-selected', 'false'); });
        pill.classList.add('active');
        pill.setAttribute('aria-selected', 'true');

        const filter = pill.dataset.filter;
        let visible = 0;

        cards.forEach(card => {
          const show = filter === 'all' || card.dataset.category === filter;
          card.style.display = show ? '' : 'none';
          if (show) visible++;
        });

        secondaryItems.forEach(item => {
          const show = filter === 'all' || item.dataset.category === filter;
          item.style.display = show ? '' : 'none';
          if (show) visible++;
        });

        if (featuredSection) {
          const showFeatured = filter === 'all' || featuredCategory === filter;
          featuredSection.style.display = showFeatured ? '' : 'none';
          if (showFeatured) visible++;
        }

        emptyState.classList.toggle('hidden', visible > 0);
        grid.classList.toggle('hidden', visible === 0);
      });
    });
  });
</script>
