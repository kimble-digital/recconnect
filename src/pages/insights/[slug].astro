---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { articles, authors } from '@/data/articles';

export function getStaticPaths() {
  return articles.map(a => ({
    params: { slug: a.slug },
    props: { article: a },
  }));
}

const { article } = Astro.props;

function formatDate(dateString: string) {
  return new Date(dateString).toLocaleDateString('en-GB', {
    day: 'numeric',
    month: 'long',
    year: 'numeric',
  });
}

function readTime(content: string) {
  return Math.max(2, Math.ceil(content.split(/\s+/).length / 230));
}

function getCategoryLabel(cat: string) {
  return cat === 'salt-report' ? 'Salt Report' : 'Rec Matters';
}

const authorData = authors[article.author as keyof typeof authors] || {
  name: article.author,
  slug: '',
  role: '',
  headshot: '',
  linkedin: '',
};

// Related articles — same category, excluding current, max 3
const related = articles
  .filter(a => a.slug !== article.slug && a.category === article.category)
  .slice(0, 3);

// Simple markdown-ish to HTML (handles bold, links, headers, lists)
function renderContent(md: string): string {
  let html = md
    // Headers
    .replace(/^### (.+)$/gm, '<h3 class="text-lg font-bold text-brand-navy mt-8 mb-3">$1</h3>')
    .replace(/^## (.+)$/gm, '<h2 class="text-xl font-bold text-brand-navy mt-10 mb-4">$1</h2>')
    // Bold
    .replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
    // Italic
    .replace(/\*(.+?)\*/g, '<em>$1</em>')
    // Links
    .replace(/\[([^\]]+)\]\(([^)]+)\)/g, '<a href="$2" class="text-primary hover:underline" target="_blank" rel="noopener noreferrer">$1</a>')
    // Bullet lists (• and - style)
    .replace(/^[•\-]\s+(.+)$/gm, '<li class="ml-4 mb-1.5">$1</li>')
    // Emoji bullets (✔️ ✨ etc)
    .replace(/^([✔️🔍🤖📊🔄💰🎯✨⚙️💻🏢🚀])\s*(.+)$/gm, '<li class="ml-4 mb-1.5">$1 $2</li>')
    // Wrap consecutive <li> in <ul>
    .replace(/(<li[^>]*>.*?<\/li>\n?)+/g, (match) => `<ul class="list-disc list-outside pl-4 my-4 space-y-1 text-slate-600">${match}</ul>`)
    // Paragraphs (double newline)
    .replace(/\n\n+/g, '</p><p class="mb-4 text-slate-600 leading-relaxed">')
    // Single newlines within paragraphs
    .replace(/\n/g, '<br/>');

  // Wrap in paragraph
  html = `<p class="mb-4 text-slate-600 leading-relaxed">${html}</p>`;

  // Clean up empty paragraphs
  html = html.replace(/<p[^>]*>\s*<\/p>/g, '');
  // Fix nested p inside headings
  html = html.replace(/<p[^>]*>\s*(<h[23])/g, '$1');
  html = html.replace(/(<\/h[23]>)\s*<\/p>/g, '$1');

  return html;
}
---

<BaseLayout
  title={article.title}
  description={article.summary}
>

  <!-- ═══ ARTICLE HEADER ═══ -->
  <section class="relative overflow-hidden bg-brand-navy pt-36 pb-10 md:pt-44 md:pb-14">
    <div class="absolute inset-0 opacity-[0.03]" style="background-image: url('data:image/svg+xml,%3Csvg width=&quot;40&quot; height=&quot;40&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;%3E%3Cpath d=&quot;M0 0h40v40H0z&quot; fill=&quot;none&quot; stroke=&quot;%23fff&quot; stroke-width=&quot;.5&quot;/%3E%3C/svg%3E');"></div>
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[600px] h-[300px] bg-primary/10 rounded-full blur-[120px]"></div>
    <div class="container-wide relative z-10">
      {/* Back link */}
      <a href="/insights" class="inline-flex items-center gap-1.5 text-sm text-slate-400 hover:text-white transition-colors mb-8">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
        </svg>
        Back to Insights
      </a>

      <div class="max-w-3xl">
        {/* Category & meta */}
        <div class="flex flex-wrap items-center gap-3 mb-4">
          <span class:list={[
            'inline-flex items-center px-3 py-1 rounded-full text-xs font-semibold',
            article.category === 'salt-report'
              ? 'bg-primary text-white'
              : 'bg-white/10 text-white',
          ]}>
            {getCategoryLabel(article.category)}
          </span>
          <span class="text-slate-500 text-sm">{formatDate(article.date)}</span>
          <span class="text-slate-600">·</span>
          <span class="text-slate-500 text-sm">{readTime(article.content)} min read</span>
          {article.trend && (
            <>
              <span class="text-slate-600">·</span>
              <span class:list={[
                'text-sm',
                article.trend === 'up' ? 'text-emerald-400' : article.trend === 'down' ? 'text-red-400' : 'text-slate-400',
              ]}>
                {article.trend === 'up' ? '↑ Market Rising' : article.trend === 'down' ? '↓ Market Cooling' : '→ Market Steady'}
              </span>
            </>
          )}
        </div>

        {/* Title */}
        <h1 class="text-3xl md:text-4xl lg:text-[2.75rem] font-bold text-white leading-tight mb-6">
          {article.title}
        </h1>

        {/* Author */}
        <div class="flex items-center gap-3">
          <div class="w-11 h-11 rounded-full bg-brand-slate overflow-hidden">
            {authorData.headshot && (
              <img src={authorData.headshot} alt={article.author} class="w-full h-full object-cover" />
            )}
          </div>
          <div>
            <p class="text-white font-medium text-sm">{article.author}</p>
            <p class="text-slate-500 text-xs">{authorData.role}</p>
          </div>
          {authorData.linkedin && (
            <a
              href={authorData.linkedin}
              target="_blank"
              rel="noopener noreferrer"
              class="ml-2 text-slate-500 hover:text-primary transition-colors"
              title={`${article.author} on LinkedIn`}
            >
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M19 3a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h14m-.5 15.5v-5.3a3.26 3.26 0 0 0-3.26-3.26c-.85 0-1.84.52-2.32 1.3v-1.11h-2.79v8.37h2.79v-4.93c0-.77.62-1.4 1.39-1.4a1.4 1.4 0 0 1 1.4 1.4v4.93h2.79M6.88 8.56a1.68 1.68 0 0 0 1.68-1.68c0-.93-.75-1.69-1.68-1.69a1.69 1.69 0 0 0-1.69 1.69c0 .93.76 1.68 1.69 1.68m1.39 9.94v-8.37H5.5v8.37h2.77z"/>
              </svg>
            </a>
          )}
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ FEATURED IMAGE ═══ -->
  {article.image && (
    <section class="bg-white">
      <div class="container-wide -mt-0">
        <div class="max-w-4xl mx-auto -mt-2">
          <div class="aspect-[2/1] rounded-xl overflow-hidden shadow-lg border border-slate-100">
            <img
              src={article.image}
              alt={article.title}
              class="w-full h-full object-cover"
            />
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- ═══ ARTICLE BODY ═══ -->
  <section class="bg-white py-10 md:py-14">
    <div class="container-wide">
      <div class="max-w-3xl mx-auto">
        {/* Summary/lede */}
        <p class="text-xl text-slate-700 leading-relaxed mb-8 font-medium border-l-4 border-primary pl-5">
          {article.summary}
        </p>

        {/* Main content */}
        <div class="article-content" set:html={renderContent(article.content)} />

        {/* Share / Back */}
        <div class="flex items-center justify-between pt-8 mt-10 border-t border-slate-200">
          <a href="/insights" class="inline-flex items-center gap-1.5 text-sm text-slate-500 hover:text-primary transition-colors">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
            </svg>
            Back to Insights
          </a>

          <div class="flex items-center gap-3">
            <span class="text-xs text-slate-400">Share:</span>
            <a
              href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(`https://recconnect.co/insights/${article.slug}`)}`}
              target="_blank"
              rel="noopener noreferrer"
              class="text-slate-400 hover:text-primary transition-colors"
              title="Share on LinkedIn"
            >
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M19 3a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h14m-.5 15.5v-5.3a3.26 3.26 0 0 0-3.26-3.26c-.85 0-1.84.52-2.32 1.3v-1.11h-2.79v8.37h2.79v-4.93c0-.77.62-1.4 1.39-1.4a1.4 1.4 0 0 1 1.4 1.4v4.93h2.79M6.88 8.56a1.68 1.68 0 0 0 1.68-1.68c0-.93-.75-1.69-1.68-1.69a1.69 1.69 0 0 0-1.69 1.69c0 .93.76 1.68 1.69 1.68m1.39 9.94v-8.37H5.5v8.37h2.77z"/>
              </svg>
            </a>
            <a
              href={`https://twitter.com/intent/tweet?url=${encodeURIComponent(`https://recconnect.co/insights/${article.slug}`)}&text=${encodeURIComponent(article.title)}`}
              target="_blank"
              rel="noopener noreferrer"
              class="text-slate-400 hover:text-primary transition-colors"
              title="Share on X"
            >
              <svg class="w-4.5 h-4.5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
              </svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ RELATED ARTICLES ═══ -->
  {related.length > 0 && (
    <section class="bg-slate-50 py-12 md:py-16 border-t border-slate-200">
      <div class="container-wide">
        <h2 class="text-xl font-bold text-brand-navy mb-6">
          More from {getCategoryLabel(article.category)}
        </h2>
        <div class="grid md:grid-cols-3 gap-6">
          {related.map(r => (
            <a href={`/insights/${r.slug}`} class="group block bg-white rounded-xl overflow-hidden border border-slate-100 hover:shadow-md transition-all">
              <div class="aspect-[16/9] overflow-hidden bg-brand-navy">
                {r.image ? (
                  <img src={r.image} alt={r.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
                ) : (
                  <div class="w-full h-full bg-gradient-to-br from-brand-navy to-brand-slate flex items-center justify-center">
                    <span class="text-4xl font-bold text-white/10">{r.category === 'salt-report' ? 'SR' : 'RM'}</span>
                  </div>
                )}
              </div>
              <div class="p-4">
                <p class="text-xs text-slate-500 mb-1.5">{formatDate(r.date)} · {readTime(r.content)} min</p>
                <h3 class="font-bold text-brand-navy text-sm leading-snug group-hover:text-primary transition-colors line-clamp-2">{r.title}</h3>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- ═══ CTA ═══ -->
  <section class="relative overflow-hidden bg-[#0a0e17] py-12">
