---
// SSR — renders on each request so Contentful changes go live instantly
export const prerender = false;

import BaseLayout from '@/layouts/BaseLayout.astro';
import { fetchEntry, getArticles } from '@/lib/contentful';
import type { ArticleSkeleton } from '@/lib/contentful/types';
import { documentToHtmlString } from '@contentful/rich-text-html-renderer';
import { BLOCKS, INLINES } from '@contentful/rich-text-types';

// ─── Fetch this article from Contentful by slug ─────────────────────
const { slug } = Astro.params;
const entry = await fetchEntry<ArticleSkeleton>('article', slug!, false);

if (!entry) {
  return Astro.redirect('/insights');
}

// Helper: extract plain text from Rich Text
function richTextToPlain(doc: any): string {
  if (!doc || typeof doc === 'string') return doc || '';
  if (!doc.content) return '';
  return doc.content
    .map((node: any) => {
      if (node.nodeType === 'paragraph' || node.nodeType?.startsWith('heading')) {
        return (node.content || []).map((c: any) => c.value || '').join('');
      }
      if (node.nodeType === 'unordered-list' || node.nodeType === 'ordered-list') {
        return (node.content || []).map((li: any) => (li.content || []).map((p: any) => (p.content || []).map((c: any) => c.value || '').join('')).join('')).join('\n');
      }
      return '';
    }).filter(Boolean).join('\n\n');
}

// Map to flat shape
const f = entry.fields as any;
const authorEntry = f.author;
const article = {
  title: f.title || '',
  slug: f.slug || '',
  date: f.publishDate || '',
  author: authorEntry?.fields?.name || '',
  authorHeadshot: authorEntry?.fields?.headshot?.fields?.file?.url
    ? `https:${authorEntry.fields.headshot.fields.file.url}`
    : '',
  authorRole: authorEntry?.fields?.role || '',
  authorLinkedin: authorEntry?.fields?.linkedIn || '',
  category: f.type === 'salt_report' ? 'salt-report' : 'rec-matters',
  summary: f.shortDescription || '',
  contentPlain: richTextToPlain(f.content),
  image: f.featuredImage?.fields?.file?.url
    ? `https:${f.featuredImage.fields.file.url}`
    : '',
  trend: '',
};

// Render Rich Text to HTML
const renderOptions = {
  renderNode: {
    [BLOCKS.PARAGRAPH]: (node: any, next: any) => `<p class="mb-4 text-slate-600 leading-relaxed">${next(node.content)}</p>`,
    [BLOCKS.HEADING_2]: (node: any, next: any) => `<h2 class="text-xl font-bold text-brand-navy mt-10 mb-4">${next(node.content)}</h2>`,
    [BLOCKS.HEADING_3]: (node: any, next: any) => `<h3 class="text-lg font-bold text-brand-navy mt-8 mb-3">${next(node.content)}</h3>`,
    [BLOCKS.UL_LIST]: (node: any, next: any) => `<ul>${next(node.content)}</ul>`,
    [BLOCKS.OL_LIST]: (node: any, next: any) => `<ol>${next(node.content)}</ol>`,
    [BLOCKS.LIST_ITEM]: (node: any, next: any) => {
      // Strip wrapping <p> tags rendered by the paragraph handler inside list items
      const inner = next(node.content).replace(/<p[^>]*>([\s\S]*?)<\/p>/g, '$1');
      return `<li class="mb-1.5 leading-relaxed">${inner}</li>`;
    },
    [BLOCKS.QUOTE]: (node: any, next: any) => `<blockquote class="border-l-4 border-primary pl-5 italic text-slate-500 my-6">${next(node.content)}</blockquote>`,
    [BLOCKS.EMBEDDED_ASSET]: (node: any) => {
      const url = node.data?.target?.fields?.file?.url;
      const alt = node.data?.target?.fields?.title || '';
      return url ? `<img src="https:${url}" alt="${alt}" class="rounded-xl my-6 w-full" />` : '';
    },
    [INLINES.HYPERLINK]: (node: any, next: any) => `<a href="${node.data.uri}" class="text-primary hover:underline" target="_blank" rel="noopener noreferrer">${next(node.content)}</a>`,
  },
};

const articleHtml = f.content ? documentToHtmlString(f.content, renderOptions) : '';

function formatDate(dateString: string) {
  return new Date(dateString).toLocaleDateString('en-GB', {
    day: 'numeric',
    month: 'long',
    year: 'numeric',
  });
}

function readTime(content: string) {
  return Math.max(2, Math.ceil(content.split(/\s+/).length / 230));
}

function getCategoryLabel(cat: string) {
  return cat === 'salt-report' ? 'Salt Report' : 'Rec Matters';
}

// Related articles — same type, excluding current, max 3
const allEntries = await getArticles({ include: 2 });
const related = allEntries
  .filter((e: any) => e.fields.slug !== article.slug && e.fields.type === f.type)
  .slice(0, 3)
  .map((e: any) => {
    const ef = e.fields as any;
    return {
      title: ef.title || '',
      slug: ef.slug || '',
      date: ef.publishDate || '',
      author: ef.author?.fields?.name || '',
      category: ef.type === 'salt_report' ? 'salt-report' : 'rec-matters',
      content: richTextToPlain(ef.content),
      image: ef.featuredImage?.fields?.file?.url
        ? `https:${ef.featuredImage.fields.file.url}`
        : '',
    };
  });
---

<BaseLayout
  title={article.title}
  description={article.summary}
>

  <!-- ═══ ARTICLE HEADER ═══ -->
  <section class="relative overflow-hidden bg-brand-navy pt-36 pb-16 md:pt-44 md:pb-20">
    {/* Subtle grid texture */}
    <div class="absolute inset-0 opacity-[0.03]" style="background-image: url('data:image/svg+xml,%3Csvg width=&quot;40&quot; height=&quot;40&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;%3E%3Cpath d=&quot;M0 0h40v40H0z&quot; fill=&quot;none&quot; stroke=&quot;%23fff&quot; stroke-width=&quot;.5&quot;/%3E%3C/svg%3E');"></div>
    {/* Glow — offset left to complement left-aligned text */}
    <div class="absolute top-0 left-0 w-[700px] h-[400px] bg-primary/8 rounded-full blur-[140px] -translate-x-1/4 -translate-y-1/4"></div>

    <div class="container-wide relative z-10">
      {/* Back link */}
      <a href="/insights" class="inline-flex items-center gap-1.5 text-sm text-slate-400 hover:text-white transition-colors mb-10 group">
        <svg class="w-3.5 h-3.5 transition-transform group-hover:-translate-x-0.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
        </svg>
        Back to Insights
      </a>

      <div class="max-w-3xl">

        {/* Category pill + meta — compact top row */}
        <div class="flex flex-wrap items-center gap-2.5 mb-5">
          <span class:list={[
            'inline-flex items-center px-3 py-1 rounded-full text-xs font-semibold tracking-wide uppercase',
            article.category === 'salt-report'
              ? 'bg-primary text-white'
              : 'bg-white/[0.08] text-slate-300 border border-white/10',
          ]}>
            {getCategoryLabel(article.category)}
          </span>
          <span class="text-slate-500 text-xs">·</span>
          <span class="text-slate-400 text-sm">{formatDate(article.date)}</span>
          <span class="text-slate-500 text-xs">·</span>
          <span class="text-slate-400 text-sm">{readTime(article.contentPlain)} min read</span>
          {article.trend && (
            <>
              <span class="text-slate-500 text-xs">·</span>
              <span class:list={[
                'text-sm font-medium',
                article.trend === 'up' ? 'text-emerald-400' : article.trend === 'down' ? 'text-red-400' : 'text-slate-400',
              ]}>
                {article.trend === 'up' ? '↑ Market Rising' : article.trend === 'down' ? '↓ Market Cooling' : '→ Market Steady'}
              </span>
            </>
          )}
        </div>

        {/* Title — bigger, more presence */}
        <h1 class="text-4xl md:text-5xl lg:text-[3.25rem] font-bold text-white leading-[1.1] tracking-tight mb-8">
          {article.title}
        </h1>

        {/* Primary accent rule */}
        <div class="w-10 h-[3px] bg-primary rounded-full mb-8"></div>

        {/* Author */}
        <div class="flex items-center gap-4">
          <div class="w-12 h-12 rounded-full bg-brand-slate overflow-hidden ring-2 ring-white/10 flex-shrink-0">
            {article.authorHeadshot
              ? <img src={article.authorHeadshot} alt={article.author} class="w-full h-full object-cover" />
              : <div class="w-full h-full flex items-center justify-center text-white/40 text-base font-bold">{article.author.charAt(0)}</div>
            }
          </div>
          <div>
            <p class="text-white font-semibold text-sm leading-tight">{article.author}</p>
            {article.authorRole && <p class="text-slate-400 text-xs mt-0.5">{article.authorRole}</p>}
          </div>
          {article.authorLinkedin && (
            <a
              href={article.authorLinkedin}
              target="_blank"
              rel="noopener noreferrer"
              class="ml-1 text-slate-500 hover:text-primary transition-colors"
              title={`${article.author} on LinkedIn`}
            >
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M19 3a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h14m-.5 15.5v-5.3a3.26 3.26 0 0 0-3.26-3.26c-.85 0-1.84.52-2.32 1.3v-1.11h-2.79v8.37h2.79v-4.93c0-.77.62-1.4 1.39-1.4a1.4 1.4 0 0 1 1.4 1.4v4.93h2.79M6.88 8.56a1.68 1.68 0 0 0 1.68-1.68c0-.93-.75-1.69-1.68-1.69a1.69 1.69 0 0 0-1.69 1.69c0 .93.76 1.68 1.69 1.68m1.39 9.94v-8.37H5.5v8.37h2.77z"/>
              </svg>
            </a>
          )}
        </div>

      </div>
    </div>
  </section>

  <!-- ═══ FEATURED IMAGE (overlaps hero → content) ═══ -->
  {article.image && (
    <section class="relative bg-white">
      <div class="absolute inset-x-0 top-0 h-1/2 bg-brand-navy"></div>
      <div class="container-wide relative z-10">
        <div class="max-w-3xl mx-auto">
          <div class="aspect-[16/9] rounded-xl overflow-hidden shadow-[0_20px_60px_-10px_rgba(0,0,0,0.35)]">
            <img
              src={article.image}
              alt={article.title}
              class="w-full h-full object-cover"
            />
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- ═══ ARTICLE BODY ═══ -->
  <section class="bg-white py-10 md:py-14">
    <div class="container-wide">
      <div class="max-w-3xl mx-auto">
        {/* Summary/lede */}
        <p class="text-xl text-slate-700 leading-relaxed mb-8 font-medium border-l-4 border-primary pl-5">
          {article.summary}
        </p>

        {/* Main content */}
        <div class="article-content" set:html={articleHtml} />

        {/* Share / Back */}
        <div class="flex items-center justify-between pt-8 mt-10 border-t border-slate-200">
          <a href="/insights" class="inline-flex items-center gap-1.5 text-sm text-slate-500 hover:text-primary transition-colors">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
            </svg>
            Back to Insights
          </a>

          <div class="flex items-center gap-3">
            <span class="text-xs text-slate-400">Share:</span>
            <a
              href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(`https://recconnect.co/insights/${article.slug}`)}`}
              target="_blank"
              rel="noopener noreferrer"
              class="text-slate-400 hover:text-primary transition-colors"
              title="Share on LinkedIn"
            >
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M19 3a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h14m-.5 15.5v-5.3a3.26 3.26 0 0 0-3.26-3.26c-.85 0-1.84.52-2.32 1.3v-1.11h-2.79v8.37h2.79v-4.93c0-.77.62-1.4 1.39-1.4a1.4 1.4 0 0 1 1.4 1.4v4.93h2.79M6.88 8.56a1.68 1.68 0 0 0 1.68-1.68c0-.93-.75-1.69-1.68-1.69a1.69 1.69 0 0 0-1.69 1.69c0 .93.76 1.68 1.69 1.68m1.39 9.94v-8.37H5.5v8.37h2.77z"/>
              </svg>
            </a>
            <a
              href={`https://twitter.com/intent/tweet?url=${encodeURIComponent(`https://recconnect.co/insights/${article.slug}`)}&text=${encodeURIComponent(article.title)}`}
              target="_blank"
              rel="noopener noreferrer"
              class="text-slate-400 hover:text-primary transition-colors"
              title="Share on X"
            >
              <svg class="w-4.5 h-4.5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
              </svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ RELATED ARTICLES ═══ -->
  {related.length > 0 && (
    <section class="bg-slate-50 py-12 md:py-16 border-t border-slate-200">
      <div class="container-wide">
        <h2 class="text-xl font-bold text-brand-navy mb-6">
          More from {getCategoryLabel(article.category)}
        </h2>
        <div class="grid md:grid-cols-3 gap-6">
          {related.map(r => (
            <a href={`/insights/${r.slug}`} class="group block bg-white rounded-xl overflow-hidden border border-slate-100 hover:shadow-md transition-all">
              <div class="aspect-[16/9] overflow-hidden bg-brand-navy">
                {r.image ? (
                  <img src={r.image} alt={r.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
                ) : (
                  <div class="w-full h-full bg-gradient-to-br from-brand-navy to-brand-slate flex items-center justify-center">
                    <span class="text-4xl font-bold text-white/10">{r.category === 'salt-report' ? 'SR' : 'RM'}</span>
                  </div>
                )}
              </div>
              <div class="p-4">
                <p class="text-xs text-slate-500 mb-1.5">{formatDate(r.date)} · {readTime(r.content)} min</p>
                <h3 class="font-bold text-brand-navy text-sm leading-snug group-hover:text-primary transition-colors line-clamp-2">{r.title}</h3>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- ═══ CTA ═══ -->
  <section class="relative overflow-hidden bg-[#0a0e17] py-12">
