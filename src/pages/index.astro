---
import BaseLayout from '@/layouts/BaseLayout.astro';
import HeroSection from '@/components/home/HeroSection.astro';
import EventSignpost from '@/components/home/EventSignpost.astro';
import ContactBar from '@/components/home/ContactBar.astro';
import MembershipValue from '@/components/home/MembershipValue.astro';
import WhatYouGet from '@/components/home/WhatYouGet.astro';
import StatsSection from '@/components/home/StatsSection.astro';
import Testimonials from '@/components/home/Testimonials.astro';
import BookPromo from '@/components/home/BookPromo.astro';
import CoreAreas from '@/components/home/CoreAreas.astro';
import PricingSection from '@/components/home/PricingSection.astro';
import FinalCTA from '@/components/home/FinalCTA.astro';
---
<BaseLayout title="Join the Club. Connect. Grow. Get Results." heroMode={true}>
  {/* ── Hook ── */}
  <HeroSection />
  <EventSignpost />
  <ContactBar />

  {/* ── Value ── */}
  <MembershipValue />
  <WhatYouGet />

  {/* ── Proof ── */}
  <StatsSection />
  <Testimonials />

  {/* ── Authority ── */}
  <BookPromo />
  <CoreAreas />

  {/* ── The ask ── */}
  <PricingSection />
  <FinalCTA />
</BaseLayout>
