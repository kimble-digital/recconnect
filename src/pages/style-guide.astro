---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout title="Style Guide" noSuffix={true}>

  <div class="sg-wrap">

    <div class="sg-header">
      <h1>RecConnect Style Guide</h1>
      <p>Typography, colours, and font weights for designers and developers.</p>
    </div>

    <!-- HEADINGS -->
    <section class="sg-section">
      <p class="section-label">Typography — Headings</p>
      <div class="type-table">
        <div class="type-row">
          <div class="type-meta">Space Grotesk / 700 / 48px</div>
          <div class="sample-heading" style="font-size:48px;line-height:1.1;font-weight:700">H1 Page Title</div>
        </div>
        <div class="type-row">
          <div class="type-meta">Space Grotesk / 700 / 36px</div>
          <div class="sample-heading" style="font-size:36px;line-height:1.2;font-weight:700">H2 Section Heading</div>
        </div>
        <div class="type-row">
          <div class="type-meta">Space Grotesk / 700 / 28px</div>
          <div class="sample-heading" style="font-size:28px;line-height:1.3;font-weight:700">H3 Sub-section</div>
        </div>
        <div class="type-row">
          <div class="type-meta">Space Grotesk / 600 / 22px</div>
          <div class="sample-heading" style="font-size:22px;line-height:1.4;font-weight:600">H4 Card Title</div>
        </div>
        <div class="type-row">
          <div class="type-meta">Space Grotesk / 600 / 18px</div>
          <div class="sample-heading" style="font-size:18px;line-height:1.4;font-weight:600">H5 Label Heading</div>
        </div>
      </div>
    </section>

    <hr class="divider" />

    <!-- BODY -->
    <section class="sg-section">
      <p class="section-label">Typography — Body (Inter)</p>
      <div class="type-table">
        <div class="type-row">
          <div class="type-meta">Inter / 300 / 16px — body</div>
          <p class="sample-body" style="font-weight:300;font-size:16px;line-height:1.7">The quick brown fox jumps over the lazy dog.</p>
        </div>
        <div class="type-row">
          <div class="type-meta">Inter / 400 / 16px — body emphasis</div>
          <p class="sample-body" style="font-weight:400;font-size:16px;line-height:1.7">The quick brown fox jumps over the lazy dog.</p>
        </div>
        <div class="type-row">
          <div class="type-meta">Inter / 500 / 14px — label / UI</div>
          <p class="sample-body" style="font-weight:500;font-size:14px;line-height:1.5">The quick brown fox jumps over the lazy dog.</p>
        </div>
        <div class="type-row">
          <div class="type-meta">Inter / 300 / 14px — caption / muted</div>
          <p class="sample-muted" style="font-weight:300;font-size:14px;line-height:1.6">The quick brown fox jumps over the lazy dog.</p>
        </div>
      </div>
    </section>

    <hr class="divider" />

    <!-- WEIGHTS -->
    <section class="sg-section">
      <p class="section-label">Inter — available weights</p>
      <div class="weight-grid">
        <div class="weight-card">
          <p class="weight-label">300 — Light</p>
          <p style="font-weight:300;font-size:16px;color:#1a1f2e">Body copy</p>
        </div>
        <div class="weight-card">
          <p class="weight-label">400 — Regular</p>
          <p style="font-weight:400;font-size:16px;color:#1a1f2e">Body emphasis</p>
        </div>
        <div class="weight-card">
          <p class="weight-label">500 — Medium</p>
          <p style="font-weight:500;font-size:16px;color:#1a1f2e">UI labels</p>
        </div>
        <div class="weight-card">
          <p class="weight-label">600 — Semibold</p>
          <p style="font-weight:600;font-size:16px;color:#1a1f2e">Buttons</p>
        </div>
        <div class="weight-card">
          <p class="weight-label">700 — Bold</p>
          <p style="font-weight:700;font-size:16px;color:#1a1f2e">Strong</p>
        </div>
        <div class="weight-card">
          <p class="weight-label">800 — Extrabold</p>
          <p style="font-weight:800;font-size:16px;color:#1a1f2e">Badges</p>
        </div>
      </div>
    </section>

    <hr class="divider" />

    <!-- BRAND COLOURS -->
    <section class="sg-section">
      <p class="section-label">Brand colours</p>

      <p class="colour-group-label">Primary</p>
      <div class="swatch-row">
        <div class="swatch" style="background:#4299e1">
          <p class="swatch-name" style="color:#fff">Primary Blue</p>
          <p class="swatch-hex" style="color:rgba(255,255,255,0.85)">#4299e1</p>
          <p class="swatch-usage" style="color:rgba(255,255,255,0.65)">CTAs, links, highlights</p>
        </div>
        <div class="swatch" style="background:#63b3ed">
          <p class="swatch-name" style="color:#1a365d">Primary Light</p>
          <p class="swatch-hex" style="color:rgba(26,54,93,0.8)">#63b3ed</p>
          <p class="swatch-usage" style="color:rgba(26,54,93,0.6)">Hover states, tints</p>
        </div>
        <div class="swatch" style="background:#3182ce">
          <p class="swatch-name" style="color:#fff">Primary Dark</p>
          <p class="swatch-hex" style="color:rgba(255,255,255,0.85)">#3182ce</p>
          <p class="swatch-usage" style="color:rgba(255,255,255,0.65)">Active / pressed states</p>
        </div>
      </div>

      <p class="colour-group-label" style="margin-top:1.5rem">Dark backgrounds</p>
      <div class="swatch-row">
        <div class="swatch" style="background:#1a1f2e">
          <p class="swatch-name" style="color:#fff">Navy</p>
          <p class="swatch-hex" style="color:rgba(255,255,255,0.85)">#1a1f2e</p>
          <p class="swatch-usage" style="color:rgba(255,255,255,0.5)">Page background</p>
        </div>
        <div class="swatch" style="background:#2d3748">
          <p class="swatch-name" style="color:#fff">Slate</p>
          <p class="swatch-hex" style="color:rgba(255,255,255,0.85)">#2d3748</p>
          <p class="swatch-usage" style="color:rgba(255,255,255,0.5)">Cards, surfaces</p>
        </div>
        <div class="swatch" style="background:#0f1218">
          <p class="swatch-name" style="color:#fff">Dark</p>
          <p class="swatch-hex" style="color:rgba(255,255,255,0.85)">#0f1218</p>
          <p class="swatch-usage" style="color:rgba(255,255,255,0.5)">Footer, deep sections</p>
        </div>
      </div>

      <p class="colour-group-label" style="margin-top:1.5rem">Neutrals</p>
      <div class="swatch-row">
        <div class="swatch" style="background:#718096">
          <p class="swatch-name" style="color:#fff">Muted</p>
          <p class="swatch-hex" style="color:rgba(255,255,255,0.85)">#718096</p>
          <p class="swatch-usage" style="color:rgba(255,255,255,0.7)">Secondary text</p>
        </div>
        <div class="swatch" style="background:#f7fafc;border:1px solid #e2e8f0">
          <p class="swatch-name" style="color:#1a1f2e">Off White</p>
          <p class="swatch-hex" style="color:#2d3748">#f7fafc</p>
          <p class="swatch-usage" style="color:#718096">Light section bg</p>
        </div>
        <div class="swatch" style="background:#fff;border:1px solid #e2e8f0">
          <p class="swatch-name" style="color:#1a1f2e">White</p>
          <p class="swatch-hex" style="color:#2d3748">#ffffff</p>
          <p class="swatch-usage" style="color:#718096">Card backgrounds</p>
        </div>
      </div>
    </section>

    <hr class="divider" />

    <!-- USAGE RULES -->
    <section class="sg-section">
      <p class="section-label">Usage rules</p>
      <div class="rules-grid">
        <div class="rule-card">
          <p class="rule-title">Headings</p>
          <p class="rule-body">Always Space Grotesk. H1–H3 use weight 700. H4–H6 use weight 600. Never use Inter for headings.</p>
        </div>
        <div class="rule-card">
          <p class="rule-title">Body copy</p>
          <p class="rule-body">Always Inter 300. Use 400 only for emphasis within body text. Never go below 300.</p>
        </div>
        <div class="rule-card">
          <p class="rule-title">Buttons &amp; UI</p>
          <p class="rule-body">Inter 500 or 600. Primary buttons use #4299e1 background with white text. Never use muted colour for interactive elements.</p>
        </div>
        <div class="rule-card">
          <p class="rule-title">Colour on dark</p>
          <p class="rule-body">Body text on dark backgrounds uses white at 90% opacity. Secondary text uses #718096. Never use pure black on navy.</p>
        </div>
      </div>
    </section>

  </div>

</BaseLayout>

<style>
  .sg-wrap {
    max-width: 48rem;
    margin: 0 auto;
    padding: 3rem 1.5rem 5rem;
  }
  .sg-header {
    margin-bottom: 3rem;
  }
  .sg-header h1 {
    color: #1a1f2e;
    margin-bottom: 0.5rem;
  }
  .sg-header p {
    color: #718096;
    font-size: 1rem;
    font-weight: 300;
  }
  .sg-section {
    margin-bottom: 3rem;
  }
  .section-label {
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #718096;
    margin-bottom: 1.25rem;
  }
  .divider {
    border: none;
    border-top: 1px solid #e2e8f0;
    margin-bottom: 3rem;
  }
  .type-table {
    display: flex;
    flex-direction: column;
  }
  .type-row {
    display: flex;
    align-items: baseline;
    gap: 2rem;
    padding: 1rem 0;
    border-bottom: 1px solid #f0f4f8;
  }
  .type-row:last-child { border-bottom: none; }
  .type-meta {
    font-size: 0.6875rem;
    color: #718096;
    min-width: 220px;
    flex-shrink: 0;
    font-family: monospace;
    padding-top: 0.2rem;
  }
  .sample-heading {
    font-family: 'Space Grotesk', system-ui, sans-serif;
    color: #1a1f2e;
  }
  .sample-body {
    color: #2d3748;
  }
  .sample-muted {
    color: #718096;
  }
  .weight-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.75rem;
  }
  .weight-card {
    background: #f7fafc;
    border: 1px solid #e2e8f0;
    border-radius: 0.5rem;
    padding: 1rem;
  }
  .weight-label {
    font-size: 0.6875rem;
    color: #718096;
    margin-bottom: 0.5rem;
    font-family: monospace;
  }
  .colour-group-label {
    font-size: 0.75rem;
    font-weight: 600;
    color: #718096;
    margin-bottom: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  .swatch-row {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.75rem;
  }
  .swatch {
    border-radius: 0.75rem;
    padding: 1.25rem;
  }
  .swatch-name {
    font-size: 0.875rem;
    font-weight: 600;
    margin-bottom: 0.25rem;
  }
  .swatch-hex {
    font-size: 0.75rem;
    font-family: monospace;
    margin-bottom: 0.5rem;
  }
  .swatch-usage {
    font-size: 0.6875rem;
  }
  .rules-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.75rem;
  }
  .rule-card {
    background: #f7fafc;
    border-radius: 0.75rem;
    padding: 1.25rem;
    border: 1px solid #e2e8f0;
  }
  .rule-title {
    font-weight: 600;
    font-size: 0.9375rem;
    color: #1a1f2e;
    margin-bottom: 0.5rem;
  }
  .rule-body {
    font-size: 0.875rem;
    font-weight: 300;
    color: #718096;
    line-height: 1.6;
  }
  @media (max-width: 640px) {
    .weight-grid { grid-template-columns: repeat(2, 1fr); }
    .swatch-row { grid-template-columns: 1fr; }
    .rules-grid { grid-template-columns: 1fr; }
    .type-row { flex-direction: column; gap: 0.25rem; }
    .type-meta { min-width: unset; }
  }
</style>
