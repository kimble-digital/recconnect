---
// ───────────────────────────────────────────────────────────────────
// Book promo - "The Agile Recruiter" by Simon Lewis.
// Self-contained home-page section. Uses the site's existing fonts.
// Place anywhere in index.astro (recommended: after <Testimonials />).
// ───────────────────────────────────────────────────────────────────
const BUY_URL = 'https://www.amazon.co.uk/dp/B0H4NF36K8?ref=cm_sw_r_ffobk_cp_ud_dp_8QP171CNN3TK5E1GSWHF&bestFormat=true';
const COVER = '/images/simon-book.jpg';

const points = [
  'Harness AI and automation to punch above your weight',
  'Lead high-performance teams with real confidence',
  'Build a business that sells itself',
  'Dominate your niche as a trusted authority',
  'Scale lean and profitable, fit for exit or investment',
];
---

<section class="bk" aria-label="The Agile Recruiter by Simon Lewis">
  <div class="bk-glow"></div>
  <div class="bk-inner">

    <div class="bk-cover">
      <a href={BUY_URL} target="_blank" rel="noopener noreferrer" aria-label="Buy The Agile Recruiter on Amazon">
        <img src={COVER} alt="The Agile Recruiter by Simon Lewis - book cover" loading="lazy" />
      </a>
    </div>

    <div class="bk-body">
      <p class="bk-eyebrow">Just published · New from our founder</p>
      <h2 class="bk-title">The Agile Recruiter</h2>
      <p class="bk-sub">A Leader's Guide to Running a Modern SME Recruitment Business</p>

      <p class="bk-lede">
        The future of recruitment isn't big, it's agile. Spray and pray is over. What's here now is a high-stakes world driven by AI, skills-based hiring and borderless talent, where the specialist who blends technology with genuine human connection comes out on top.
      </p>

      <ul class="bk-list">
        {points.map((p) => (
          <li>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
            <span>{p}</span>
          </li>
        ))}
      </ul>

      <blockquote class="bk-quote">
        "Essential reading for any aspirational SME recruiter who wants to push performance and remain relevant in a rapidly changing world."
        <cite>Laura Clarke</cite>
      </blockquote>

      <div class="bk-cta">
        <a href={BUY_URL} target="_blank" rel="noopener noreferrer" class="bk-btn">
          Buy on Amazon
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </a>
        <span class="bk-price">Kindle £6.73 &nbsp;·&nbsp; Paperback £10.99 &nbsp;·&nbsp; 167 pages</span>
      </div>

      <p class="bk-by">By Simon Lewis, founder of RecConnect, with contributions from some of the industry's sharpest minds.</p>
    </div>
  </div>
</section>

<style>
  .bk { position: relative; overflow: hidden; background: #0d1424; color: #fff; padding: 5rem 1.5rem; }
  .bk-glow { position: absolute; left: -10%; top: 10%; width: 640px; height: 520px; background: rgba(232,150,40,0.18); filter: blur(150px); border-radius: 50%; pointer-events: none; }

  .bk-inner { position: relative; z-index: 1; max-width: 70rem; margin: 0 auto; display: flex; align-items: center; gap: 3.5rem; }

  .bk-cover { flex: 0 0 auto; }
  .bk-cover a { display: block; transform: rotate(-2deg); transition: transform 0.4s ease; }
  .bk-cover a:hover { transform: rotate(0deg) translateY(-4px); }
  .bk-cover img { width: 280px; max-width: 38vw; height: auto; border-radius: 0.4rem; box-shadow: 0 30px 60px -20px rgba(0,0,0,0.7), 0 0 0 1px rgba(255,255,255,0.06); }

  .bk-body { flex: 1 1 auto; min-width: 0; }
  .bk-eyebrow { font-size: 0.8rem; font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase; color: #f0a838; margin-bottom: 0.9rem; }
  .bk-title { font-family: 'Space Grotesk', sans-serif; font-size: clamp(2.2rem, 4vw, 3.2rem); font-weight: 700; line-height: 1.05; color: #fff; margin: 0 0 0.5rem; }
  .bk-sub { font-size: 1.05rem; color: rgba(255,255,255,0.65); margin-bottom: 1.5rem; }
  .bk-lede { font-size: 1.05rem; line-height: 1.7; color: rgba(255,255,255,0.82); font-weight: 300; margin-bottom: 1.5rem; }

  .bk-list { list-style: none; margin: 0 0 1.75rem; padding: 0; display: grid; gap: 0.7rem; }
  .bk-list li { display: flex; align-items: flex-start; gap: 0.7rem; color: rgba(255,255,255,0.85); font-weight: 300; }
  .bk-list svg { width: 1.2rem; height: 1.2rem; color: #f0a838; flex-shrink: 0; margin-top: 0.15rem; }

  .bk-quote { border-left: 2px solid rgba(240,168,56,0.6); margin: 0 0 1.9rem; padding: 0.2rem 0 0.2rem 1.1rem; font-style: italic; color: rgba(255,255,255,0.78); line-height: 1.6; }
  .bk-quote cite { display: block; margin-top: 0.5rem; font-style: normal; font-size: 0.85rem; color: rgba(255,255,255,0.5); }

  .bk-cta { display: flex; align-items: center; flex-wrap: wrap; gap: 1rem 1.5rem; margin-bottom: 1.25rem; }
  .bk-btn {
    display: inline-flex; align-items: center; gap: 0.55rem;
    background: #f0a838; color: #1a1206;
    font-weight: 600; font-size: 1.05rem;
    padding: 0.85rem 1.8rem; border-radius: 0.6rem;
    text-decoration: none;
    box-shadow: 0 12px 30px -10px rgba(240,168,56,0.7);
    transition: transform 0.18s ease, background 0.2s ease;
  }
  .bk-btn:hover { transform: translateY(-2px); background: #ffb84d; }
  .bk-btn svg { width: 1.1rem; height: 1.1rem; }
  .bk-price { font-size: 0.9rem; color: rgba(255,255,255,0.6); }

  .bk-by { font-size: 0.85rem; color: rgba(255,255,255,0.5); line-height: 1.6; }

  @media (max-width: 820px) {
    .bk-inner { flex-direction: column; align-items: flex-start; gap: 2.5rem; }
    .bk-cover { align-self: center; }
    .bk-cover img { max-width: 60vw; }
  }
</style>
