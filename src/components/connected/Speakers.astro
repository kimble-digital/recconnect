---
import { speakers } from '@/data/connected';
---

<section class="relative bg-black py-20 md:py-28 overflow-hidden">
  <div class="absolute top-1/3 -right-32 w-[500px] h-[500px] rounded-full bg-[#ff6a13]/10 blur-[150px]"></div>
  <div class="container-wide relative z-10">
    <div class="max-w-2xl mb-14 reveal">
      <p class="c-kicker">On the bill</p>
      <h2 class="c-display uppercase text-5xl md:text-7xl text-white leading-[0.95] mb-4">Your speakers</h2>
      <p class="text-lg text-white/65 font-light">A line-up of voices worth clearing your diary for. More names to be announced.</p>
    </div>

    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-4 md:gap-5">
      {speakers.map((s, i) => (
        <div class="c-speaker reveal" style={`--d:${i * 60}ms`}>
          <div class="c-speaker-img">
            <img src={s.img} alt={s.name} loading="lazy" />
            <div class="c-speaker-grade"></div>
          </div>
          <div class="c-speaker-name">
            <p class="font-bold text-white leading-tight">{s.name}</p>
            {s.role && <p class="text-white/55 text-sm font-light leading-snug mt-1">{s.role}</p>}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
