---
// ───────────────────────────────────────────────────────────────────
// CONNECTED 2025 reel - contained, lazy video section.
// Loads NOTHING until the visitor clicks play (preload="none" + poster),
// so the page stays fast even with a large file.
//
// Two ways to source the video:
//   1. EMBED_URL  → set a YouTube/Vimeo *embed* URL (recommended for big
//      files). e.g. 'https://www.youtube.com/embed/XXXX' or
//      'https://player.vimeo.com/video/XXXX'. Leave '' to self-host.
//   2. Self-host → set VIDEO_SRC to the mp4 in /public/video.
//      Compress first (a 90s reel should be ~10-25MB, not 200MB).
//
// POSTER is the still shown before play - swap for a real frame from the
// video if you have one (ffmpeg -i video.mp4 -ss 3 -vframes 1 poster.jpg).
// ───────────────────────────────────────────────────────────────────
const EMBED_URL = '';
const VIDEO_SRC = '/video/CONNECTED2025.mp4';
const POSTER = '/images/box/people1.jpg';
---

<section class="vr bg-[#0a0a0a] py-20 md:py-28 overflow-hidden relative">
  <div class="absolute top-1/3 left-1/2 -translate-x-1/2 w-[700px] h-[360px] rounded-full bg-[#ff6a13]/10 blur-[160px]"></div>
  <div class="container-wide relative z-10">

    <div class="max-w-2xl mb-12 reveal">
      <p class="c-kicker">Last year at CONNECTED</p>
      <h2 class="c-display uppercase text-5xl md:text-7xl text-white leading-[0.95] mb-4">Don't take our word for it</h2>
      <p class="text-lg text-white/65 font-light">Ninety seconds of the 2025 experience, straight from the people who were in the room.</p>
    </div>

    <div class="vr-frame reveal">
      {EMBED_URL ? (
        <iframe
          class="vr-embed"
          src={EMBED_URL}
          title="CONNECTED 2025 reel"
          loading="lazy"
          frameborder="0"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
          allowfullscreen
        ></iframe>
      ) : (
        <>
          <video class="vr-video" preload="none" poster={POSTER} playsinline>
            <source src={VIDEO_SRC} type="video/mp4" />
          </video>
          <button class="vr-play" aria-label="Play the CONNECTED 2025 reel">
            <span class="vr-play-ring">
              <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M8 5v14l11-7z"/></svg>
            </span>
            <span class="vr-play-label">Watch the 2025 reel</span>
          </button>
        </>
      )}
    </div>
  </div>
</section>

<style>
  .vr-frame {
    position: relative;
    max-width: 58rem;
    margin: 0 auto;
    aspect-ratio: 16 / 9;
    border-radius: 0.9rem;
    overflow: hidden;
    border: 1px solid rgba(255,255,255,0.12);
    background: #000;
    box-shadow: 0 40px 90px -40px rgba(255,106,19,0.5);
  }
  .vr-video, .vr-embed { position: absolute; inset: 0; width: 100%; height: 100%; display: block; }
  .vr-video { object-fit: cover; }
  .vr-embed { border: 0; }

  .vr-play {
    position: absolute; inset: 0;
    display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 1rem;
    background: linear-gradient(to top, rgba(0,0,0,0.45), rgba(0,0,0,0.15));
    cursor: pointer; border: 0; color: #fff;
    transition: opacity 0.25s ease;
  }
  .vr-frame.is-playing .vr-play { opacity: 0; pointer-events: none; }
  .vr-play-ring {
    width: 84px; height: 84px; border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    background: #ff6a13; color: #0a0a0a;
    box-shadow: 0 0 0 0 rgba(255,106,19,0.6), 0 14px 34px -10px rgba(255,106,19,0.8);
    animation: vr-pulse 2.4s ease-out infinite;
    transition: transform 0.2s ease;
  }
  .vr-play:hover .vr-play-ring { transform: scale(1.06); }
  .vr-play-ring svg { width: 34px; height: 34px; margin-left: 4px; }
  .vr-play-label {
    font-family: 'Bebas Neue', sans-serif; text-transform: uppercase;
    letter-spacing: 0.14em; font-size: 1.05rem; color: #fff;
    text-shadow: 0 2px 10px rgba(0,0,0,0.6);
  }
  @keyframes vr-pulse {
    0% { box-shadow: 0 0 0 0 rgba(255,106,19,0.5), 0 14px 34px -10px rgba(255,106,19,0.8); }
    70% { box-shadow: 0 0 0 22px rgba(255,106,19,0), 0 14px 34px -10px rgba(255,106,19,0.8); }
    100% { box-shadow: 0 0 0 0 rgba(255,106,19,0), 0 14px 34px -10px rgba(255,106,19,0.8); }
  }
  @media (prefers-reduced-motion: reduce) { .vr-play-ring { animation: none; } }
</style>

<script>
  document.querySelectorAll<HTMLElement>('.vr-frame').forEach((frame) => {
    const video = frame.querySelector<HTMLVideoElement>('video');
    const overlay = frame.querySelector<HTMLElement>('.vr-play');
    if (!video || !overlay) return;
    overlay.addEventListener('click', () => {
      video.setAttribute('controls', '');
      frame.classList.add('is-playing');
      video.play();
    });
    video.addEventListener('play', () => frame.classList.add('is-playing'));
  });
</script>
