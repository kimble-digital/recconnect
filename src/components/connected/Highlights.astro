---
import { highlights } from '@/data/connected';
---

<section class="relative bg-black py-20 md:py-28 overflow-hidden">
  <div class="absolute bottom-0 right-0 w-[600px] h-[400px] rounded-full bg-[#4299e1]/8 blur-[150px]"></div>
  <div class="container-wide relative z-10">
    <div class="max-w-2xl mb-14 reveal">
      <p class="c-kicker">What you walk away with</p>
      <h2 class="c-display uppercase text-5xl md:text-7xl text-white leading-[0.95]">
        High energy, fresh perspectives, lasting rewards.
      </h2>
    </div>
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {highlights.map((h, i) => (
        <div class="c-card reveal" style={`--d:${i * 70}ms`}>
          <div class="c-card-num">{String(i + 1).padStart(2, '0')}</div>
          <h3 class="text-xl font-bold text-white mb-2.5">{h.title}</h3>
          <p class="text-white/65 font-light leading-relaxed">{h.body}</p>
        </div>
      ))}
    </div>
  </div>
</section>
