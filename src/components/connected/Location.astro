---
---

<section class="relative bg-[#0a0a0a] py-20 md:py-28 overflow-hidden">
  <div class="container-wide">
    <div class="grid lg:grid-cols-2 gap-12 items-center">
      <div class="reveal">
        <p class="c-kicker">The venue</p>
        <h2 class="c-display uppercase text-5xl md:text-7xl text-white leading-[0.95] mb-6">BOX Piccadilly</h2>
        <p class="text-lg text-white/70 font-light leading-relaxed mb-8">
          One of London's most striking immersive venues, right in the heart of Piccadilly Circus. The perfect backdrop for a day that refuses to sit still.
        </p>
        <div class="flex items-start gap-3 text-white/80 mb-8">
          <svg class="w-5 h-5 text-[#ff6a13] mt-1 shrink-0" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
          <span class="font-light">BOX Piccadilly, 23 Piccadilly Circus, London W1D 7EF</span>
        </div>
        <div class="flex flex-wrap gap-3">
          <a href="https://maps.google.com/?daddr=51.5105587,-0.1343011&mode=transit" target="_blank" rel="noopener noreferrer" class="c-btn-outline-sm">Public transport</a>
          <a href="https://maps.google.com/?daddr=51.5105587,-0.1343011&mode=walking" target="_blank" rel="noopener noreferrer" class="c-btn-outline-sm">Walking</a>
          <a href="https://maps.google.com/?daddr=51.5105587,-0.1343011&mode=driving" target="_blank" rel="noopener noreferrer" class="c-btn-outline-sm">Driving</a>
        </div>
      </div>
      <div class="reveal">
        <div class="c-venue-img">
          <img src="/images/box/Box4.webp" alt="Inside BOX Piccadilly" loading="lazy" />
          <img src="/images/box/Box-Logo-transparant-orange.webp" alt="BOX" class="c-venue-logo" />
        </div>
      </div>
    </div>
  </div>
</section>
