---
import '@/styles/global.css';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import EventTopBar from '@/components/home/EventTopBar.astro';

interface Props {
  title: string;
  description?: string;
  /** Full URL or local path for OG image. Full https:// URLs used as-is. */
  image?: string;
  /** Pass true on homepage to enable large logo + scroll-shrink header */
  heroMode?: boolean;
  /** Comma-separated keywords for meta keywords tag */
  keywords?: string;
  /** Override the auto-generated canonical URL */
  canonical?: string;
  /** Set true when title already includes site name — prevents " | RecConnect" being appended */
  noSuffix?: boolean;
  /** Set false to hide the CONNECTED 2026 announcement bar on a given page */
  eventBar?: boolean;
}

const {
  title,
  description = "Connect with the UK's leading recruitment professionals. From intimate networking lunches to comprehensive business summits.",
  image = '/og-image.png',
  heroMode = false,
  keywords,
  canonical,
  noSuffix = false,
  eventBar = true,
} = Astro.props;

const siteUrl = import.meta.env.PUBLIC_SITE_URL || 'https://recconnect.co';

// Canonical: use explicit override, else auto-generate from current URL
const canonicalUrl = canonical || new URL(Astro.url.pathname, siteUrl).toString();

// Title: append site name unless noSuffix or it already contains RecConnect
const pageTitle = noSuffix || title.includes('RecConnect')
  ? title
  : `${title} | RecConnect`;

// OG image: full https:// URLs used as-is; local paths get siteUrl prepended
const ogImage = image.startsWith('http') ? image : `${siteUrl}${image}`;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Google Fonts — loaded as link tags so Vite/PostCSS cannot strip them -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet" />

    <!-- Self-hosted font preloads (backup once woff2 files are replaced via fontsource) -->
    <link rel="preload" href="/fonts/inter-300.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/inter-400.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/inter-500.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/inter-600.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/inter-700.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/inter-800.woff2" as="font" type="font/woff2" crossorigin />

    <!-- SEO -->
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    {keywords && <meta name="keywords" content={keywords} />}
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Additional head content (JSON-LD, page-specific meta, etc.) -->
    <slot name="head" />

    <!-- Announcement bar offset: push the fixed site header down by the bar
         height AND shift the page content down to match, so the bar never
         overlays the logo/nav and the lowered header never overlaps the page
         content below it. Only active when the bar is shown (body.eventbar-on).
         --eventbar-h is refined by JS below. -->
    <style is:global>
      body.eventbar-on header { top: var(--eventbar-h, 42px) !important; }
      body.eventbar-on main { padding-top: var(--eventbar-h, 42px); }
    </style>

    <!-- Google Analytics -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-SNYGXXJV0K"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-SNYGXXJV0K');
    </script>
  </head>
  <body class={eventBar ? 'eventbar-on' : undefined}>
    {eventBar && <EventTopBar />}
    <Header heroMode={heroMode} />
    <main>
      <slot />
    </main>
    <Footer />

    {eventBar && (
      <script is:inline>
        (function () {
          function sync() {
            var bar = document.querySelector('.etb');
            if (bar) document.body.style.setProperty('--eventbar-h', bar.offsetHeight + 'px');
          }
          sync();
          window.addEventListener('resize', sync);
        })();
      </script>
    )}
  </body>
</html>
